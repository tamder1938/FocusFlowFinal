<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FocusFlowFinal.ViewModels"
        xmlns:models="using:FocusFlowFinal.Models"
        x:Class="FocusFlowFinal.Views.TaskDialog"
        x:DataType="vm:TaskDialogViewModel"
        Title="{Binding Loc[TaskTitle]}" Width="420" Height="760"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<Window.Styles>

		<!-- ── Поля ввода: светлый/тёмный фон без рамки, скругление 8 ── -->
		<Style Selector="TextBox, ComboBox, DatePicker">
			<Setter Property="Background"      Value="{DynamicResource InputBackgroundBrush}"/>
			<Setter Property="Foreground"      Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="BorderBrush"     Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Padding"         Value="10,8"/>
			<Setter Property="Margin"          Value="0,0,0,12"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>
		<Style Selector="TextBox:focus, ComboBox:focus, DatePicker:focus">
			<Setter Property="BorderBrush"     Value="{DynamicResource AccentBackground}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>

		<!-- ── Подписи полей ───────────────────────────────────────── -->
		<Style Selector="TextBlock.field-label">
			<Setter Property="FontSize"   Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="Margin"     Value="0,0,0,6"/>
		</Style>

		<!-- ── Чекбоксы с подписью ─────────────────────────────────── -->
		<Style Selector="CheckBox">
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="FontSize"   Value="13"/>
			<Setter Property="Margin"     Value="0,0,0,4"/>
		</Style>

		<!-- ── Pill-кнопки приоритета ──────────────────────────────── -->
		<Style Selector="ToggleButton.priority-pill">
			<Setter Property="Height"          Value="36"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Margin"          Value="3,0"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
			<Setter Property="Background"      Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="Foreground"      Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.15"/>
					<BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
				</Transitions>
			</Setter>
		</Style>

		<!-- Высокий — выбран: красный -->
		<Style Selector="ToggleButton.priority-pill.high:checked">
			<Setter Property="Background"  Value="#EF4444"/>
			<Setter Property="BorderBrush" Value="#EF4444"/>
			<Setter Property="Foreground"  Value="White"/>
		</Style>
		<Style Selector="ToggleButton.priority-pill.high:checked /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background"  Value="#EF4444"/>
		</Style>
		<!-- Средний — выбран: оранжевый -->
		<Style Selector="ToggleButton.priority-pill.medium:checked">
			<Setter Property="Background"  Value="#F59E0B"/>
			<Setter Property="BorderBrush" Value="#F59E0B"/>
			<Setter Property="Foreground"  Value="White"/>
		</Style>
		<Style Selector="ToggleButton.priority-pill.medium:checked /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background"  Value="#F59E0B"/>
		</Style>
		<!-- Низкий — выбран: зелёный -->
		<Style Selector="ToggleButton.priority-pill.low:checked">
			<Setter Property="Background"  Value="#10B981"/>
			<Setter Property="BorderBrush" Value="#10B981"/>
			<Setter Property="Foreground"  Value="White"/>
		</Style>
		<Style Selector="ToggleButton.priority-pill.low:checked /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background"  Value="#10B981"/>
		</Style>

		<!-- ── Кнопки внизу: Отмена / Сохранить / Удалить ──────────── -->
		<Style Selector="Button.secondary-action">
			<Setter Property="Background"      Value="{DynamicResource SecondaryActionBrush}"/>
			<Setter Property="Foreground"      Value="{DynamicResource SecondaryActionFgBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Height"          Value="40"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.primary-action">
			<Setter Property="Background"      Value="{DynamicResource PrimaryActionBrush}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Height"          Value="40"/>
			<Setter Property="FontWeight"      Value="Bold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.primary-action:pointerover">
			<Setter Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}"/>
		</Style>
		<Style Selector="Button.danger-action">
			<Setter Property="Background"      Value="#EF4444"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Height"          Value="40"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>

		<!-- ── Строка подзадачи ───────────────────────────────────────── -->
		<Style Selector="Button.subtask-remove">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Width"           Value="26"/>
			<Setter Property="Height"          Value="26"/>
			<Setter Property="CornerRadius"    Value="5"/>
			<Setter Property="Padding"         Value="0"/>
			<Setter Property="Foreground"      Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="FontSize"        Value="14"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment"   Value="Center"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.subtask-remove:pointerover">
			<Setter Property="Background" Value="#EF4444"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector="Button.add-subtask-btn">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground"      Value="{DynamicResource AccentBackground}"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Padding"         Value="0,4"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="HorizontalAlignment" Value="Left"/>
		</Style>

		<!-- ── Кнопка "шестерёнка" управления проектами ────────────── -->
		<Style Selector="Button.gear-btn">
			<Setter Property="Background"      Value="{DynamicResource AccentLightBrush}"/>
			<Setter Property="Foreground"      Value="{DynamicResource AccentTextBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="Width"           Value="40"/>
			<Setter Property="Height"          Value="40"/>
			<Setter Property="Padding"         Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment"   Value="Center"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
	</Window.Styles>

	<ScrollViewer>
		<StackPanel Margin="20" Spacing="0">

			<!-- Заголовок и крестик -->
			<Grid ColumnDefinitions="*, Auto" Margin="0,0,0,16">
				<TextBlock Grid.Column="0"
                           Text="{Binding Loc[TaskTitle]}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
				<Button Grid.Column="1" Content="✕"
                        Command="{Binding CancelCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        FontSize="16" Padding="6" Cursor="Hand"/>
			</Grid>

			<!-- Название -->
			<TextBlock Classes="field-label" Text="{Binding Loc[TaskNameLbl]}"/>
			<TextBox Text="{Binding Title}" Watermark="{Binding Loc[TaskNameWatermark]}"/>

			<!-- Описание -->
			<TextBlock Classes="field-label" Text="{Binding Loc[TaskDesc]}"/>
			<TextBox Text="{Binding Description}"
                     Watermark="{Binding Loc[TaskDescWatermark]}"
                     Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>

			<!-- Шаблон -->
			<TextBlock Classes="field-label" Text="{Binding Loc[LoadTemplateHint]}"/>
			<ComboBox ItemsSource="{Binding TaskTemplates}"
                      SelectedItem="{Binding SelectedTaskTemplate}"
                      PlaceholderText="{Binding Loc[ChooseTemplate]}"
                      HorizontalAlignment="Stretch">
				<ComboBox.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryTextBrush}"/>
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>

			<!-- Дата -->
			<CheckBox Content="{Binding Loc[HasDateOpt]}" IsChecked="{Binding HasDate}"/>
			<DatePicker SelectedDate="{Binding DueDate}" IsEnabled="{Binding HasDate}"/>

			<!-- Время -->
			<CheckBox Content="{Binding Loc[IsTimeBoundOpt]}" IsChecked="{Binding IsTimeBound}"/>

			<!-- Время начала -->
			<StackPanel IsEnabled="{Binding IsTimeBound}" Margin="0,0,0,4">
				<TextBlock Classes="field-label" Text="{Binding Loc[StartTimeLbl]}" Margin="0,0,0,4"/>
				<Grid ColumnDefinitions="Auto,Auto,Auto,Auto">
					<TextBlock Grid.Column="0" Text="{Binding Loc[HourLabel]}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
					<TextBox Grid.Column="1" Text="{Binding StartHour}" Width="60" Margin="0,0,12,0"/>
					<TextBlock Grid.Column="2" Text="{Binding Loc[MinLabel]}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
					<TextBox Grid.Column="3" Text="{Binding StartMinute}" Width="60"/>
				</Grid>
			</StackPanel>

			<!-- Время окончания -->
			<StackPanel IsEnabled="{Binding IsTimeBound}" Margin="0,0,0,12">
				<TextBlock Classes="field-label" Text="{Binding Loc[EndTimeLbl]}" Margin="0,0,0,4"/>
				<Grid ColumnDefinitions="Auto,Auto,Auto,Auto">
					<TextBlock Grid.Column="0" Text="{Binding Loc[HourLabel]}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
					<TextBox Grid.Column="1" Text="{Binding EndHour}" Width="60" Margin="0,0,12,0"/>
					<TextBlock Grid.Column="2" Text="{Binding Loc[MinLabel]}"
                               VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
					<TextBox Grid.Column="3" Text="{Binding EndMinute}" Width="60"/>
				</Grid>
			</StackPanel>

			<!-- Длительность -->
			<CheckBox Content="{Binding Loc[IsDurationOpt]}" IsChecked="{Binding IsDurationSet}"/>
			<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,12" IsEnabled="{Binding IsDurationSet}">
				<TextBlock Text="{Binding Loc[DurationLabel]}" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
				<TextBox Text="{Binding DurationMinutes}" Width="90" Margin="0"/>
			</StackPanel>

			<!-- Приоритет -->
			<TextBlock Classes="field-label" Text="{Binding Loc[PriorityLabel]}" Margin="0,4,0,8"/>
			<Grid ColumnDefinitions="*,*,*" Margin="0,0,0,16">
				<ToggleButton Grid.Column="0" Content="{Binding Loc[FilterHigh]}"
                              IsChecked="{Binding IsHighSelected, Mode=OneWay}"
                              Command="{Binding SetPriorityCommand}" CommandParameter="0"
                              Classes="priority-pill high"/>
				<ToggleButton Grid.Column="1" Content="{Binding Loc[FilterMedium]}"
                              IsChecked="{Binding IsMediumSelected, Mode=OneWay}"
                              Command="{Binding SetPriorityCommand}" CommandParameter="1"
                              Classes="priority-pill medium"/>
				<ToggleButton Grid.Column="2" Content="{Binding Loc[FilterLow]}"
                              IsChecked="{Binding IsLowSelected, Mode=OneWay}"
                              Command="{Binding SetPriorityCommand}" CommandParameter="2"
                              Classes="priority-pill low"/>
			</Grid>

			<!-- Проект -->
			<TextBlock Classes="field-label" Text="{Binding Loc[ProjectLabel]}"/>
			<Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
				<ComboBox Grid.Column="0"
                          ItemsSource="{Binding ProjectsList}"
                          SelectedItem="{Binding SelectedProject}"
                          HorizontalAlignment="Stretch" Margin="0,0,8,0">
					<ComboBox.ItemTemplate>
						<DataTemplate DataType="models:ProjectItem">
							<StackPanel Orientation="Horizontal" Spacing="8">
								<Border Width="10" Height="10" CornerRadius="5"
                                        Background="{Binding Color}" VerticalAlignment="Center"/>
								<TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
							</StackPanel>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<Button Grid.Column="1" Classes="gear-btn"
                        Command="{Binding OpenProjectsManagementCommand}">
					<PathIcon Width="16" Height="16"
                              Data="M19.14 12.94c.04-.3.06-.61.06-.94s-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
				</Button>
			</Grid>

			<Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

			<!-- Подзадачи -->
			<TextBlock Classes="field-label" Text="{Binding Loc[SubtasksLabel]}" Margin="0,0,0,8"/>
			<ItemsControl ItemsSource="{Binding Subtasks}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:SubtaskEditItem">
						<Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,6">
							<CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted}"
							          VerticalAlignment="Center" Margin="0,0,6,0"/>
							<TextBox Grid.Column="1" Text="{Binding Title}"
							         PlaceholderText="Название подзадачи"
							         Margin="0" Height="34"/>
							<Button Grid.Column="2" Classes="subtask-remove"
							        Content="✕" Margin="6,0,0,0"
							        Command="{Binding RemoveCommand}"/>
						</Grid>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
			<Button Classes="add-subtask-btn"
			        Content="{Binding Loc[AddSubtaskBtn]}"
			        Command="{Binding AddSubtaskCommand}"
			        Margin="0,2,0,16"/>

			<Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>

			<!-- Сохранить как шаблон -->
			<CheckBox Content="{Binding Loc[SaveAsTemplateLbl]}" IsChecked="{Binding SaveAsTemplate}"/>
			<StackPanel IsEnabled="{Binding SaveAsTemplate}" Spacing="6" Margin="0,6,0,16">
				<TextBox Watermark="{Binding Loc[TemplateNameWatermark]}" Text="{Binding TemplateName}" Margin="0"/>
				<TextBlock Text="{Binding Loc[TemplateHint]}" FontSize="10"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
			</StackPanel>

			<!-- Кнопки -->
			<Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
				<Button Grid.Column="0" Classes="danger-action"
                        Content="{Binding Loc[DeleteBtn]}"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsEditMode}"
                        Width="90" Margin="0,0,8,0"/>
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
					<Button Classes="secondary-action"
                            Content="{Binding Loc[CancelBtn]}"
                            Command="{Binding CancelCommand}"
                            Width="100"
                            HorizontalContentAlignment="Center"/>
					<Button Classes="primary-action"
                            Content="{Binding Loc[SaveBtn]}"
                            Command="{Binding SaveCommand}"
                            Width="120"
                            HorizontalContentAlignment="Center"/>
				</StackPanel>
			</Grid>

		</StackPanel>
	</ScrollViewer>
</Window>
