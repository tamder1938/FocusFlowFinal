<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
             xmlns:models="clr-namespace:FocusFlowFinal.Models"
             xmlns:conv="clr-namespace:FocusFlowFinal.Converters"
             x:Class="FocusFlowFinal.Views.DayView"
             x:DataType="vm:DayViewModel">

	<UserControl.Styles>
		<Style Selector="Button.day-nav">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground"      Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="FontSize"        Value="18"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>
		<Style Selector="Button.add-event-btn">
			<Setter Property="Background"      Value="{DynamicResource AccentBackground}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="14,6"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.add-event-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
		</Style>
		<Style Selector="Button.task-chip">
			<Setter Property="Background"      Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius"    Value="14"/>
			<Setter Property="Margin"          Value="4,2"/>
			<Setter Property="Padding"         Value="10,6"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.task-chip:pointerover">
			<Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
		</Style>
	</UserControl.Styles>

	<DockPanel>

		<!-- Навигация -->
		<Grid DockPanel.Dock="Top" ColumnDefinitions="Auto, *, Auto" Margin="14,10,14,8">
			<Button Grid.Column="0" Classes="day-nav" Content="‹"
                    Command="{Binding PreviousDayCommand}"/>
			<TextBlock Grid.Column="1" Text="{Binding SelectedDateFormatted}"
                       FontSize="15" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
			<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
				<Button Classes="day-nav" Content="›" Command="{Binding NextDayCommand}"/>
				<Button Classes="add-event-btn"
                        Content="📤 Другу"
                        Command="{Binding OpenSharedEventCommand}"
                        IsVisible="{Binding HasSharedCalSvc}"
                        ToolTip.Tip="Добавить событие в календарь друга"/>
				<Button Classes="add-event-btn"
                        Content="{Binding Loc[AddEventBtn]}"
                        Command="{Binding AddEventCommand}"/>
			</StackPanel>
		</Grid>

		<!-- Чипы задач на день -->
		<Border DockPanel.Dock="Top"
                Background="{DynamicResource CardSecondaryBackgroundBrush}"
                CornerRadius="10" Margin="12,0,12,8" Padding="10"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                IsVisible="{Binding DayTasks.Count}">
			<Grid ColumnDefinitions="60, *">
				<TextBlock Grid.Column="0" Text="{Binding Loc[Tasks]}" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
				<ItemsControl Grid.Column="1" ItemsSource="{Binding DayTasks}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="models:TaskItem">
							<Button Classes="task-chip"
                                    Command="{Binding $parent[UserControl].((vm:DayViewModel)DataContext).EditTaskFromCalendarCommand}"
                                    CommandParameter="{Binding}">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<Ellipse Width="6" Height="6" Fill="{Binding Color}" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
									<Border IsVisible="{Binding HasLocation}"
                                            Background="{DynamicResource AccentBackground}"
                                            CornerRadius="4" Padding="4,1">
										<TextBlock FontSize="10" Foreground="White" VerticalAlignment="Center">
											<Run Text="&#128205;"/>
											<Run Text="{Binding LocationShort}"/>
										</TextBlock>
									</Border>
								</StackPanel>
							</Button>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Grid>
		</Border>

		<!-- Часовая сетка -->
		<ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Margin="6,0,6,6">
			<Grid ColumnDefinitions="56,*" Height="1440" Background="Transparent">

				<!-- Подписи часов -->
				<ItemsControl Grid.Column="0" ItemsSource="{Binding HourStrings}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="x:String">
							<Border Height="60" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
								<TextBlock Text="{Binding}" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2,0,0"/>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<!-- Сетка часов + события -->
				<Grid Grid.Column="1" Background="Transparent" x:Name="EventsAreaGrid">
					<ItemsControl ItemsSource="{Binding HourStrings}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="x:String">
								<Border Height="60" BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1" Background="Transparent"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<!--
					  Canvas.Top/Left должны быть на прямом дочернем элементе Canvas
					  (ContentPresenter), а не внутри DataTemplate.
					  Используем ItemContainerTheme для передачи координат на контейнер.
					-->
					<ItemsControl ItemsSource="{Binding EventDisplayItems}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate><Canvas Background="Transparent"/></ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemContainerTheme>
							<ControlTheme TargetType="ContentPresenter"
							              x:DataType="models:EventDisplayItem">
								<Setter Property="Canvas.Top"  Value="{Binding Top}"/>
								<Setter Property="Canvas.Left" Value="{Binding Left}"/>
								<Setter Property="Width"       Value="{Binding Width}"/>
								<Setter Property="Height"      Value="{Binding Height}"/>
							</ControlTheme>
						</ItemsControl.ItemContainerTheme>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:EventDisplayItem">
								<Border Background="{Binding Color}" CornerRadius="6" Padding="8,6"
								        Tag="{Binding OriginalEvent}" Cursor="Hand"
								        ToolTip.Tip="{Binding Title}"
								        Tapped="EventTapped" Opacity="0.95"
								        BoxShadow="0 2 4 0 #18000000">
									<StackPanel Spacing="2">
										<TextBlock Text="{Binding Title}" TextWrapping="Wrap"
										           FontSize="11" FontWeight="Bold" Foreground="White"
										           MaxLines="2"/>
										<TextBlock Text="{Binding TimeLabel}" FontSize="10"
										           Foreground="White" Opacity="0.85"
										           IsVisible="{Binding TimeLabel, Converter={x:Static conv:NullOrEmptyToBoolConverter.IsNotNullOrEmpty}}"/>
										<TextBlock FontSize="10" Foreground="White" Opacity="0.9"
										           IsVisible="{Binding HasLocation}">
											<Run Text="&#128205;"/>
											<Run Text="{Binding LocationShort}"/>
										</TextBlock>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<!-- Friend events (read-only layer) -->
					<ItemsControl ItemsSource="{Binding FriendEventDisplayItems}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate><Canvas Background="Transparent"/></ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemContainerTheme>
							<ControlTheme TargetType="ContentPresenter"
							              x:DataType="models:FriendEventDisplayItem">
								<Setter Property="Canvas.Top"  Value="{Binding Top}"/>
								<Setter Property="Canvas.Left" Value="{Binding Left}"/>
								<Setter Property="Width"       Value="{Binding Width}"/>
								<Setter Property="Height"      Value="{Binding Height}"/>
							</ControlTheme>
						</ItemsControl.ItemContainerTheme>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:FriendEventDisplayItem">
								<Border BorderBrush="{Binding Color}" BorderThickness="1" CornerRadius="5"
								        Padding="6,4" Background="#22000000" Opacity="0.8"
								        ToolTip.Tip="{Binding Title}">
									<StackPanel Spacing="1">
										<TextBlock FontSize="9" FontWeight="SemiBold"
										           Foreground="{Binding Color}"
										           Text="{Binding FriendName}"/>
										<TextBlock Text="{Binding Title}" FontSize="10"
										           Foreground="White" TextWrapping="Wrap" MaxLines="2"/>
										<TextBlock Text="{Binding TimeLabel}" FontSize="9"
										           Foreground="White" Opacity="0.7"/>
									</StackPanel>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</Grid>
			</Grid>
		</ScrollViewer>
	</DockPanel>
</UserControl>
