<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
             xmlns:models="clr-namespace:FocusFlowFinal.Models"
             xmlns:conv="clr-namespace:FocusFlowFinal.Converters"
             x:Class="FocusFlowFinal.Views.TaskListView"
             x:DataType="vm:TaskListViewModel">

	<UserControl.Resources>
		<conv:PriorityToBrushConverter          x:Key="PriorityToBrushConverter"/>
		<conv:StringToBrushConverter            x:Key="StringToBrushConverter"/>
		<conv:InverseBoolConverter              x:Key="InverseBoolConverter"/>
		<conv:BoolToStrikethroughConverter      x:Key="BoolToStrikethroughConverter"/>
		<conv:IsCompletedToOpacityConverter     x:Key="IsCompletedToOpacityConverter"/>
	</UserControl.Resources>

	<UserControl.Styles>
		<!-- ListBoxItem — без стандартного выделения -->
		<Style Selector="ListBoxItem">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="FocusAdorner" Value="{x:Null}"/>
			<Setter Property="Template">
				<ControlTemplate>
					<ContentPresenter Name="PART_ContentPresenter"
                                      Background="{TemplateBinding Background}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"/>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>

		<!-- Карточка задачи -->
		<Style Selector="Border.task-card">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Margin" Value="0,4"/>
			<Setter Property="BorderThickness" Value="2"/>
			<Setter Property="BorderBrush" Value="Transparent"/>
		</Style>
		<Style Selector="ListBoxItem:pointerover Border.task-card">
			<Setter Property="BorderBrush" Value="{DynamicResource AccentBackground}"/>
		</Style>

		<!-- Кнопка редактирования -->
		<Style Selector="Button.edit-btn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Width" Value="28"/>
			<Setter Property="Height" Value="28"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
		</Style>
		<Style Selector="Button.edit-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
		</Style>

		<!-- Кнопка Play -->
		<Style Selector="Button.play-btn">
			<Setter Property="Width" Value="32"/>
			<Setter Property="Height" Value="32"/>
			<Setter Property="CornerRadius" Value="16"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.12"/>
				</Transitions>
			</Setter>
		</Style>
		<Style Selector="Button.play-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
		</Style>

		<!-- Кнопки фильтра -->
		<Style Selector="Button.filter-btn">
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="10,4"/>
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>
		<Style Selector="Button.filter-btn.active">
			<Setter Property="Background" Value="{DynamicResource AccentBackground}"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- Чекбокс выполнения -->
		<Style Selector="CheckBox.task-check">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Margin" Value="0,0,8,0"/>
		</Style>

		<!-- Фильтры статуса: серый / синий / фиолетовый -->
		<Style Selector="Button.filter-btn.filter-status-all">
			<Setter Property="Background" Value="#4B5563"/>
			<Setter Property="Foreground" Value="#D1D5DB"/>
		</Style>
		<Style Selector="Button.filter-btn.filter-status-all.active">
			<Setter Property="Background" Value="#6B7280"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector="Button.filter-btn.filter-status-active">
			<Setter Property="Background" Value="#0369A1"/>
			<Setter Property="Foreground" Value="#7DD3FC"/>
		</Style>
		<Style Selector="Button.filter-btn.filter-status-active.active">
			<Setter Property="Background" Value="#0EA5E9"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
		<Style Selector="Button.filter-btn.filter-status-done">
			<Setter Property="Background" Value="#5B21B6"/>
			<Setter Property="Foreground" Value="#C4B5FD"/>
		</Style>
		<Style Selector="Button.filter-btn.filter-status-done.active">
			<Setter Property="Background" Value="#7C3AED"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- Подзадача в карточке -->
		<Style Selector="CheckBox.subtask-check">
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Margin" Value="0,0,6,0"/>
			<Setter Property="MinWidth" Value="0"/>
			<Setter Property="Padding" Value="0"/>
		</Style>
	</UserControl.Styles>

	<DockPanel Margin="15">

		<!-- Заголовок + выбор проекта -->
		<Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
			<TextBlock Grid.Column="0" Text="{Binding Loc[Tasks]}"
                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
			<ComboBox Grid.Column="1"
                      ItemsSource="{Binding Projects}"
                      SelectedItem="{Binding SelectedProject}"
                      Width="160" VerticalAlignment="Center"
                      Background="{DynamicResource CardBackgroundBrush}"
                      Foreground="{DynamicResource PrimaryTextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}">
				<ComboBox.ItemTemplate>
					<DataTemplate DataType="models:ProjectItem">
						<StackPanel Orientation="Horizontal" Spacing="8">
							<Border Width="10" Height="10" CornerRadius="5"
                                    Background="{Binding Color}" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Name}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
						</StackPanel>
					</DataTemplate>
				</ComboBox.ItemTemplate>
			</ComboBox>
		</Grid>

		<!-- Фильтры по приоритету -->
		<WrapPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
			<Button Classes="filter-btn" Content="{Binding Loc[FilterAll]}" Margin="0,0,4,0"
                    Command="{Binding SetPriorityFilterCommand}" CommandParameter="-1"
                    Background="#6B7280" Foreground="White"/>
			<Button Classes="filter-btn" Content="{Binding Loc[FilterHigh]}" Margin="0,0,4,0"
                    Command="{Binding SetPriorityFilterCommand}" CommandParameter="0"
                    Background="#EF4444" Foreground="White"/>
			<Button Classes="filter-btn" Content="{Binding Loc[FilterMedium]}" Margin="0,0,4,0"
                    Command="{Binding SetPriorityFilterCommand}" CommandParameter="1"
                    Background="#F59E0B" Foreground="White"/>
			<Button Classes="filter-btn" Content="{Binding Loc[FilterLow]}"
                    Command="{Binding SetPriorityFilterCommand}" CommandParameter="2"
                    Background="#10B981" Foreground="White"/>
		</WrapPanel>

		<!-- Фильтр по статусу выполнения -->
		<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,10">
			<Button Classes="filter-btn filter-status-all"
                    Classes.active="{Binding CompletionFilter, Converter={x:Static conv:CompletionFilterConverter.IsAll}}"
                    Content="{Binding Loc[AllFilter]}"
                    Command="{Binding SetCompletionFilterCommand}" CommandParameter="0"/>
			<Button Classes="filter-btn filter-status-active"
                    Classes.active="{Binding CompletionFilter, Converter={x:Static conv:CompletionFilterConverter.IsActive}}"
                    Content="{Binding Loc[ActiveFilter]}"
                    Command="{Binding SetCompletionFilterCommand}" CommandParameter="1"/>
			<Button Classes="filter-btn filter-status-done"
                    Classes.active="{Binding CompletionFilter, Converter={x:Static conv:CompletionFilterConverter.IsDone}}"
                    Content="{Binding Loc[CompletedFilter]}"
                    Command="{Binding SetCompletionFilterCommand}" CommandParameter="2"/>
		</StackPanel>

		<!-- Единый список задач: активные сначала, затем выполненные -->
		<ListBox ItemsSource="{Binding FilteredTasks}"
                 SelectedItem="{Binding SelectedTask}"
                 Background="Transparent">
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="models:TaskItem">
					<Border Classes="task-card" Padding="0"
					        Opacity="{Binding IsCompleted, Converter={StaticResource IsCompletedToOpacityConverter}}">
						<Grid ColumnDefinitions="4,*">
							<!-- Цветная полоска проекта слева -->
							<Border Grid.Column="0"
                                    Background="{Binding ProjectColor, Converter={StaticResource StringToBrushConverter}}"
                                    CornerRadius="10,0,0,10" VerticalAlignment="Stretch"/>

							<!-- Содержимое карточки -->
							<Grid Grid.Column="1" Margin="10,8,10,8">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>

								<!-- Строка 0: чекбокс + текст + кнопки -->
								<Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto">

									<!-- Чекбокс выполнения — активен всегда -->
									<CheckBox Grid.Column="0" Classes="task-check"
                                              IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                              Command="{Binding $parent[UserControl].DataContext.ToggleTaskCompletionCommand}"
                                              CommandParameter="{Binding}"/>

									<!-- Название + описание + длительность + счётчик подзадач -->
									<StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
										<TextBlock Text="{Binding Title}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"/>
										<TextBlock Text="{Binding Description}"
                                                   FontSize="12" Opacity="0.55"
                                                   TextWrapping="Wrap"
                                                   IsVisible="{Binding Description, Converter={x:Static conv:NullOrEmptyToBoolConverter.IsNotNullOrEmpty}}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
										<TextBlock Text="{Binding DurationText}"
                                                   FontSize="11" Opacity="0.5"
                                                   IsVisible="{Binding HasDuration}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
										<TextBlock Text="{Binding SubtasksProgress}"
                                                   FontSize="11" Opacity="0.7"
                                                   IsVisible="{Binding HasSubtasks}"
                                                   Foreground="{DynamicResource AccentBackground}"/>
									</StackPanel>

									<!-- Кнопка редактирования (только для незавершённых) -->
									<Button Grid.Column="2" Classes="edit-btn" Margin="8,0,4,0"
                                            IsVisible="{Binding IsCompleted, Converter={StaticResource InverseBoolConverter}}"
                                            Command="{Binding $parent[UserControl].DataContext.EditTaskCommand}"
                                            CommandParameter="{Binding}">
										<PathIcon Width="13" Height="13"
                                                  Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
                                                  Foreground="{DynamicResource SecondaryTextBrush}"/>
									</Button>

									<!-- Кнопка Play (только если HasDuration и не выполнена) -->
									<Button Grid.Column="3" Classes="play-btn"
                                            IsVisible="{Binding CanStartTimer}"
                                            Command="{Binding $parent[UserControl].DataContext.StartTimerCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="Запустить таймер">
										<PathIcon Width="14" Height="14"
                                                  Data="M8 5v14l11-7z"
                                                  Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}"/>
									</Button>
								</Grid>

								<!-- Строка 1: список подзадач (если есть) -->
								<ItemsControl Grid.Row="1"
								              ItemsSource="{Binding SubtaskViewItems}"
								              IsVisible="{Binding HasSubtasks}"
								              Margin="26,4,4,2">
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="models:SubtaskViewItem">
											<StackPanel Orientation="Horizontal"
											            Margin="0,3,0,0"
											            VerticalAlignment="Center">
												<CheckBox Classes="subtask-check"
												          IsChecked="{Binding IsCompleted}"/>
												<TextBlock Text="{Binding Title}"
												           FontSize="12"
												           VerticalAlignment="Center"
												           TextWrapping="Wrap"
												           TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"
												           Foreground="{DynamicResource SecondaryTextBrush}"
												           Opacity="0.85"/>
											</StackPanel>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</Grid>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>
</UserControl>
