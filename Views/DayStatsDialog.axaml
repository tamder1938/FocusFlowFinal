<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        xmlns:services="clr-namespace:FocusFlowFinal.Services"
        x:Class="FocusFlowFinal.Views.DayStatsDialog"
        x:CompileBindings="False"
        Title="{Binding DateTitle}"
        Width="440" Height="580"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Styles>
        <Style Selector="Border.Section">
            <Setter Property="Background"     Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius"   Value="8"/>
            <Setter Property="Padding"        Value="12,10"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin"         Value="0,0,0,8"/>
        </Style>
        <Style Selector="TextBlock.SectionHdr">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
        <Style Selector="TextBlock.ItemLine">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin"     Value="0,1"/>
        </Style>
        <Style Selector="TextBlock.DimItem">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin"     Value="0,1"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="56, *, 56">

        <!-- Шапка -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}">
            <StackPanel VerticalAlignment="Center" Margin="18,0">
                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Title]}"
                           FontSize="11" Foreground="{DynamicResource OnAccentBrush}" Opacity="0.8"/>
                <TextBlock Text="{Binding DateTitle}"
                           FontSize="16" FontWeight="Bold" Foreground="{DynamicResource OnAccentBrush}"/>
            </StackPanel>
        </Border>

        <!-- Содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,14,16,8" Spacing="0">

                <!-- Нет данных -->
                <Border Classes="Section" IsVisible="{Binding !HasAnyData}">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_NoData]}"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Задачи -->
                <Border Classes="Section" IsVisible="{Binding HasTasks}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Tasks]}"
                                       Classes="SectionHdr" Margin="0"/>
                            <TextBlock Text="{Binding TasksLabel}"
                                       FontSize="11" Foreground="{DynamicResource AccentTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding CompletedTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Classes="ItemLine" Foreground="#10B981"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Привычки -->
                <Border Classes="Section" IsVisible="{Binding HasHabits}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                            <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Habits]}"
                                       Classes="SectionHdr" Margin="0"/>
                            <TextBlock Text="{Binding HabitsLabel}"
                                       FontSize="11" Foreground="{DynamicResource AccentTextBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding DoneHabits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Classes="ItemLine" Foreground="#10B981"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding SkippedHabits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Classes="DimItem"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- События -->
                <Border Classes="Section" IsVisible="{Binding HasEvents}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Events]}"
                                   Classes="SectionHdr"/>
                        <ItemsControl ItemsSource="{Binding Events}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Classes="ItemLine"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Помодоро -->
                <Border Classes="Section" IsVisible="{Binding HasPomodoro}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Pomodoro]}"
                                   Classes="SectionHdr" VerticalAlignment="Center" Margin="0"/>
                        <TextBlock Text="{Binding PomodoroLabel}" Classes="ItemLine" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Тренировка -->
                <Border Classes="Section" IsVisible="{Binding HasWorkout}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Workout]}"
                                   Classes="SectionHdr"/>
                        <TextBlock Text="{Binding WorkoutLabel}" Classes="ItemLine" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Настроение -->
                <Border Classes="Section" IsVisible="{Binding HasMood}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Mood]}"
                                   Classes="SectionHdr" VerticalAlignment="Center" Margin="0"/>
                        <TextBlock Text="{Binding MoodLabel}" Classes="ItemLine"
                                   Foreground="{Binding MoodColor}" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Заметка -->
                <Border Classes="Section" IsVisible="{Binding HasNote}">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Note]}"
                                   Classes="SectionHdr"/>
                        <TextBlock Text="{Binding NoteLabel}" Classes="DimItem"
                                   TextWrapping="Wrap" MaxLines="4"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Кнопка закрыть -->
        <Border Grid.Row="2" Background="{DynamicResource CardSecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">
            <Button Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DayStats_Close]}"
                    Command="{Binding CloseWindowCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    Background="{DynamicResource PrimaryActionBrush}" Foreground="White"
                    BorderThickness="0" CornerRadius="7" Padding="24,8"
                    FontWeight="SemiBold" Cursor="Hand"
                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
