<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FocusFlowFinal.Views.WishlistEditorWindow"
        x:CompileBindings="False"
        Title="{Binding Title}"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<DockPanel Margin="12">

		<!-- Toolbar -->
		<Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" Margin="0,0,0,10">
			<TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>

			<!-- Filter button (with active indicator) -->
			<Button Grid.Column="1"
                    Command="{Binding OpenFiltersCommand}"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="12,6" FontSize="13" Cursor="Hand"
                    Margin="0,0,6,0" ToolTip.Tip="Фильтры">
				<StackPanel Orientation="Horizontal" Spacing="4">
					<TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center"/>
					<TextBlock Text="Фильтр" VerticalAlignment="Center"/>
					<Border IsVisible="{Binding HasActiveFilters}"
                            Background="{DynamicResource AccentBackground}"
                            CornerRadius="10" Padding="5,1" Margin="2,0,0,0">
						<TextBlock Text="{Binding ActiveFilterCount}" FontSize="10"
                                   Foreground="White" FontWeight="Bold"/>
					</Border>
				</StackPanel>
			</Button>

			<!-- Clear filters (visible when filters active) -->
			<Button Grid.Column="2"
                    IsVisible="{Binding HasActiveFilters}"
                    Content="✕ Сбросить"
                    Command="{Binding ClearFiltersCommand}"
                    Background="Transparent"
                    Foreground="#EF4444"
                    BorderBrush="#EF4444" BorderThickness="1"
                    CornerRadius="6" Padding="10,6" FontSize="12" Cursor="Hand"
                    Margin="0,0,6,0"/>

			<!-- Conditional formatting button -->
			<!-- Export menu -->
			<Button Grid.Column="3"
                    Content="↓CSV"
                    Command="{Binding ExportCsvCommand}"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8,6" FontSize="12" Cursor="Hand"
                    Margin="0,0,4,0" ToolTip.Tip="Экспорт CSV"/>
			<Button Grid.Column="4"
                    Content="↓XLS"
                    Command="{Binding ExportExcelCommand}"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8,6" FontSize="12" Cursor="Hand"
                    Margin="0,0,4,0" ToolTip.Tip="Экспорт Excel"/>
			<Button Grid.Column="5"
                    Content="↑CSV"
                    Command="{Binding ImportCsvCommand}"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8,6" FontSize="12" Cursor="Hand"
                    Margin="0,0,6,0" ToolTip.Tip="Импорт CSV"/>

			<Button Grid.Column="6"
                    Content="🎨"
                    Command="{Binding OpenCondFormatsCommand}"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="10,6" FontSize="14" Cursor="Hand"
                    Margin="0,0,6,0" ToolTip.Tip="Условное форматирование"/>

			<Button Grid.Column="7"
                    Content="+ Строка"
                    Command="{Binding AddRowCommand}"
                    Background="{DynamicResource AccentBackground}" Foreground="White"
                    BorderThickness="0" CornerRadius="6" Padding="12,6"
                    FontSize="13" Cursor="Hand" Margin="0,0,8,0"/>
			<Button Grid.Column="8"
                    Content="Закрыть"
                    Command="{Binding CloseCommand}"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="12,6" Cursor="Hand"/>
		</Grid>

		<!-- Table built in code-behind -->
		<ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
			<Grid x:Name="TableContainer"/>
		</ScrollViewer>

	</DockPanel>
</Window>
