<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        xmlns:models="clr-namespace:FocusFlowFinal.Models.Wishlist"
        x:Class="FocusFlowFinal.Views.ColumnSetupDialog"
        x:DataType="vm:ColumnSetupViewModel"
        Title="Настройка вишлиста"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<DockPanel Margin="16">

		<!-- Header -->
		<Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
			<TextBlock Grid.Column="0" Text="Настройка вишлиста" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
			<Button Grid.Column="1" Content="✕" Command="{Binding CancelCommand}"
                    Background="Transparent" BorderThickness="0" Foreground="Gray"/>
		</Grid>

		<!-- Bottom buttons -->
		<Grid DockPanel.Dock="Bottom" ColumnDefinitions="*, *" Margin="0,12,0,0">
			<Button Grid.Column="0" Content="Отмена" Command="{Binding CancelCommand}"
                    Margin="5" Height="36" CornerRadius="6"/>
			<Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveCommand}"
                    Margin="5" Background="{DynamicResource PrimaryActionBrush}"
                    Foreground="White" Height="36" CornerRadius="6" FontWeight="Bold"/>
		</Grid>

		<!-- Content -->
		<ScrollViewer>
			<StackPanel Spacing="12">
				<!-- Name -->
				<TextBlock Text="Название вишлиста:" FontSize="12" Foreground="Gray"/>
				<TextBox Text="{Binding WishlistName}" Watermark="Например, Список подарков"/>

				<!-- Description -->
				<TextBlock Text="Описание (необязательно):" FontSize="12" Foreground="Gray"/>
				<TextBox Text="{Binding WishlistDescription}" Watermark="Краткое описание"/>

				<!-- Column templates -->
				<TextBlock Text="Быстрые шаблоны колонок:" FontSize="12" Foreground="Gray" Margin="0,4,0,0"/>
				<StackPanel Orientation="Horizontal" Spacing="8">
					<Button Content="🎁 Подарки" Command="{Binding ApplyGiftsTemplateCommand}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" FontSize="12" Cursor="Hand"/>
					<Button Content="📚 Книги" Command="{Binding ApplyBooksTemplateCommand}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" FontSize="12" Cursor="Hand"/>
					<Button Content="🎬 Фильмы" Command="{Binding ApplyFilmsTemplateCommand}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6" FontSize="12" Cursor="Hand"/>
				</StackPanel>

				<!-- Columns header -->
				<Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
					<TextBlock Grid.Column="0" Text="Колонки:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
					<Button Grid.Column="1" Content="+ Добавить колонку" Command="{Binding AddColumnCommand}"
                            Background="{DynamicResource AccentLightBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            BorderThickness="0" CornerRadius="6" Padding="10,6" FontSize="12" Cursor="Hand"/>
				</Grid>

				<!-- Column list -->
				<ItemsControl ItemsSource="{Binding Columns}">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:ColumnEditItem">
							<Border Margin="0,3" Padding="10,8" CornerRadius="8"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
								<Grid RowDefinitions="Auto, Auto">

									<Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto, Auto">
										<TextBox Grid.Column="0" Text="{Binding Name}"
                                                 Watermark="Имя колонки" Margin="0,0,8,0"
                                                 Background="Transparent" BorderThickness="0"
                                                 FontWeight="SemiBold"/>
										<ComboBox Grid.Column="1" ItemsSource="{x:Static vm:ColumnSetupViewModel.AllColumnTypes}"
                                                  SelectedItem="{Binding Type}"
                                                  Width="110" Margin="0,0,4,0"/>
										<Button Grid.Column="2" Content="↑" Command="{Binding MoveUpCommand}"
                                                Background="Transparent" BorderThickness="0" Padding="4,0" Cursor="Hand"/>
										<Button Grid.Column="3" Content="↓" Command="{Binding MoveDownCommand}"
                                                Background="Transparent" BorderThickness="0" Padding="4,0" Cursor="Hand"/>
										<Button Grid.Column="4" Content="✕" Command="{Binding RemoveCommand}"
                                                Background="Transparent" Foreground="#EF4444"
                                                BorderThickness="0" FontSize="14" Padding="4,0" Cursor="Hand"/>
									</Grid>

									<!-- Dropdown options (visible only for Dropdown type) -->
									<StackPanel Grid.Row="1" IsVisible="{Binding IsDropdown}" Margin="0,6,0,0">
										<TextBlock Text="Варианты (через запятую):" FontSize="11" Foreground="Gray"/>
										<TextBox Text="{Binding OptionsText}" Watermark="Например: Да, Нет, Планирую"
                                                 Background="Transparent" Margin="0,2,0,0"/>
									</StackPanel>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

			</StackPanel>
		</ScrollViewer>
	</DockPanel>
</Window>
