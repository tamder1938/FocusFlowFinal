<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        x:Class="FocusFlowFinal.Views.FriendsWindow"
        x:CompileBindings="False"
        Title="Друзья"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <DockPanel Margin="20">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Друзья" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,12"/>

        <!-- Not authenticated -->
        <StackPanel DockPanel.Dock="Top"
                    IsVisible="{Binding !IsAuthenticated}"
                    HorizontalAlignment="Center" Margin="0,40,0,0" Spacing="8">
            <TextBlock Text="🔒" FontSize="40" HorizontalAlignment="Center"/>
            <TextBlock Text="Войдите в аккаунт, чтобы использовать раздел «Друзья»"
                       FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
        </StackPanel>

        <DockPanel DockPanel.Dock="Top" IsVisible="{Binding IsAuthenticated}">

            <!-- Error -->
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"/>

            <!-- Search -->
            <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,14">
                <TextBox Grid.Column="0"
                         Text="{Binding SearchQuery}"
                         Watermark="Поиск по email..."
                         CornerRadius="8" Padding="10,8" FontSize="13"
                         Background="{DynamicResource InputBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                <Button Grid.Column="1"
                        Content="Найти"
                        Command="{Binding SearchCommand}"
                        Background="{DynamicResource AccentBackground}" Foreground="White"
                        BorderThickness="0" CornerRadius="8" Padding="14,8"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand" Margin="8,0,0,0"/>
            </Grid>

            <!-- Search results -->
            <StackPanel DockPanel.Dock="Top"
                        IsVisible="{Binding HasSearchResults}"
                        Margin="0,0,0,12" Spacing="4">
                <TextBlock Text="Результаты поиска:" FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                <ItemsControl ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" CornerRadius="8" Margin="0,2"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding Username}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding Email}" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="+ Добавить"
                                            Command="{Binding $parent[Window].((vm:FriendsViewModel)DataContext).SendRequestCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource AccentBackground}" Foreground="White"
                                            BorderThickness="0" CornerRadius="6" Padding="10,5"
                                            FontSize="12" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Tabs -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,12">
                <Button Content="Друзья"
                        Command="{Binding SelectFriendsTabCommand}"
                        Background="{DynamicResource AccentBackground}" Foreground="White"
                        BorderThickness="0" FontSize="13" Padding="12,6" CornerRadius="6" Cursor="Hand"/>
                <Button Content="Запросы"
                        Command="{Binding SelectIncomingTabCommand}"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                        FontSize="13" Padding="12,6" CornerRadius="6" Cursor="Hand"/>
                <Button Content="Исходящие"
                        Command="{Binding SelectOutgoingTabCommand}"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                        FontSize="13" Padding="12,6" CornerRadius="6" Cursor="Hand"/>
            </StackPanel>

            <!-- Friends tab -->
            <ScrollViewer DockPanel.Dock="Top" IsVisible="{Binding IsFriendsTabActive}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Нет друзей. Найдите пользователя через поиск."
                               IsVisible="{Binding FriendsEmpty}"
                               FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    <ItemsControl ItemsSource="{Binding Friends}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" CornerRadius="8" Margin="0,2"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding RequesterProfile.Username}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding RequesterProfile.Email}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Удалить"
                                                Command="{Binding $parent[Window].((vm:FriendsViewModel)DataContext).RemoveFriendCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#EF4444"
                                                BorderThickness="0" Padding="8,4" FontSize="12" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Incoming tab -->
            <ScrollViewer DockPanel.Dock="Top" IsVisible="{Binding IsIncomingTabActive}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Входящих запросов нет."
                               IsVisible="{Binding IncomingEmpty}"
                               FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    <ItemsControl ItemsSource="{Binding IncomingRequests}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" CornerRadius="8" Margin="0,2"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid ColumnDefinitions="*, Auto, Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding RequesterProfile.Username}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding RequesterProfile.Email}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="✓ Принять"
                                                Command="{Binding $parent[Window].((vm:FriendsViewModel)DataContext).AcceptCommand}"
                                                CommandParameter="{Binding}"
                                                Background="#10B981" Foreground="White"
                                                BorderThickness="0" CornerRadius="6" Padding="10,5"
                                                FontSize="12" Cursor="Hand" Margin="0,0,6,0"/>
                                        <Button Grid.Column="2"
                                                Content="✕ Отклонить"
                                                Command="{Binding $parent[Window].((vm:FriendsViewModel)DataContext).DeclineCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#EF4444"
                                                BorderBrush="#EF4444" BorderThickness="1"
                                                CornerRadius="6" Padding="10,5"
                                                FontSize="12" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Outgoing tab -->
            <ScrollViewer DockPanel.Dock="Top" IsVisible="{Binding IsOutgoingTabActive}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="Нет исходящих запросов."
                               IsVisible="{Binding OutgoingEmpty}"
                               FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    <ItemsControl ItemsSource="{Binding OutgoingRequests}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" CornerRadius="8" Margin="0,2"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding AddresseeProfile.Username}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding AddresseeProfile.Email}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="Ожидает ответа..." FontSize="11"
                                                       Foreground="#F59E0B"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Отменить"
                                                Command="{Binding $parent[Window].((vm:FriendsViewModel)DataContext).CancelRequestCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" Foreground="#EF4444"
                                                BorderThickness="0" Padding="8,4" FontSize="12" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

        </DockPanel>

    </DockPanel>
</Window>
