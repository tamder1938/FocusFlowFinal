<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FocusFlowFinal.Views.WishlistFilterDialog"
        x:CompileBindings="False"
        Title="Фильтры"
        Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<DockPanel Margin="16">

		<!-- Header -->
		<Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
			<TextBlock Text="Фильтры" FontSize="17" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
			<Button Grid.Column="1" Content="✕" Command="{Binding CancelCommand}"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource SecondaryTextBrush}" FontSize="16"/>
		</Grid>

		<!-- Bottom buttons -->
		<StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="0,12,0,0">

			<!-- Save filter panel -->
			<Border IsVisible="{Binding IsSavingFilter}"
                    Background="{DynamicResource CardSecondaryBackgroundBrush}"
                    CornerRadius="8" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
				<Grid ColumnDefinitions="*, Auto, Auto">
					<TextBox Grid.Column="0" Text="{Binding SaveFilterName}" Watermark="Название фильтра"
                             Margin="0,0,8,0"/>
					<Button Grid.Column="1" Content="Сохранить" Command="{Binding ConfirmSaveFilterCommand}"
                            Background="{DynamicResource AccentBackground}" Foreground="White"
                            BorderThickness="0" CornerRadius="6" Padding="10,6" Margin="0,0,6,0"/>
					<Button Grid.Column="2" Content="Отмена" Command="{Binding CancelSaveFilterCommand}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="10,6"/>
				</Grid>
			</Border>

			<!-- Action buttons -->
			<Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto">
				<Button Grid.Column="0"
                        Content="💾 Сохранить фильтр"
                        Command="{Binding BeginSaveFilterCommand}"
                        IsVisible="{Binding !IsSavingFilter}"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="10,6" FontSize="12"/>
				<Button Grid.Column="2"
                        Content="Сбросить"
                        Command="{Binding ResetCommand}"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="12,6" Margin="0,0,6,0"/>
				<Button Grid.Column="3"
                        Content="Отмена"
                        Command="{Binding CancelCommand}"
                        Background="{DynamicResource ButtonBackgroundBrush}"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="12,6" Margin="0,0,6,0"/>
				<Button Grid.Column="4"
                        Content="Применить"
                        Command="{Binding ApplyCommand}"
                        Background="{DynamicResource AccentBackground}" Foreground="White"
                        BorderThickness="0" CornerRadius="6" Padding="14,6" FontWeight="SemiBold"/>
			</Grid>
		</StackPanel>

		<!-- Saved filters -->
		<StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8"
                    IsVisible="{Binding SavedFilters.Count}">
			<TextBlock Text="Сохранённые фильтры:" FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
			<ItemsControl ItemsSource="{Binding SavedFilters}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="0,2" Padding="8,4" CornerRadius="6"
                                Background="{DynamicResource CardSecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
							<Grid ColumnDefinitions="*, Auto, Auto">
								<TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"/>
								<Button Grid.Column="1"
                                        Content="Загрузить"
                                        Command="{Binding $parent[Window].DataContext.LoadSavedFilterCommand}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource AccentLightBrush}"
                                        Foreground="{DynamicResource AccentTextBrush}"
                                        BorderThickness="0" CornerRadius="4"
                                        Padding="8,4" FontSize="11" Margin="4,0"/>
								<Button Grid.Column="2"
                                        Content="✕"
                                        Command="{Binding $parent[Window].DataContext.DeleteSavedFilterCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#EF4444"
                                        BorderThickness="0" FontSize="13" Padding="4,0"/>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>

		<!-- Filter rules per column -->
		<ScrollViewer>
			<ItemsControl ItemsSource="{Binding Rules}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Border Margin="0,4" Padding="10,8" CornerRadius="8"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
							<StackPanel Spacing="6">

								<!-- Column name -->
								<TextBlock Text="{Binding Column.Name}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

								<!-- Condition picker -->
								<ComboBox ItemsSource="{Binding ConditionLabels}"
                                          SelectedIndex="{Binding SelectedConditionIndex}"
                                          HorizontalAlignment="Stretch"/>

								<!-- Text value (single) -->
								<TextBox IsVisible="{Binding HasTextValue}"
                                         Text="{Binding FilterValue}"
                                         Watermark="Значение..." />

								<!-- Second value for Between -->
								<Grid IsVisible="{Binding IsBetween}" ColumnDefinitions="*, Auto, *">
									<TextBox Grid.Column="0" Text="{Binding FilterValue}"
                                             Watermark="От"/>
									<TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center"
                                               Margin="6,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
									<TextBox Grid.Column="2" Text="{Binding FilterValue2}"
                                             Watermark="До"/>
								</Grid>

								<!-- Dropdown multi-select checkboxes -->
								<ItemsControl IsVisible="{Binding IsIn}" ItemsSource="{Binding CheckBoxOptions}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<CheckBox Content="{Binding Option}"
                                                      IsChecked="{Binding IsChecked}"
                                                      Margin="0,2"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>

	</DockPanel>
</Window>
