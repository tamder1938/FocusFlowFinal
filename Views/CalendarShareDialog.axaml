<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        x:Class="FocusFlowFinal.Views.CalendarShareDialog"
        x:CompileBindings="False"
        Title="Общий доступ к календарю"
        Width="460" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <DockPanel Margin="20">

        <TextBlock DockPanel.Dock="Top"
                   Text="Общий доступ к календарю"
                   FontSize="17" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="Друзья смогут просматривать или синхронизировать ваш календарь"
                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,16"/>

        <!-- Close -->
        <Button DockPanel.Dock="Bottom"
                Content="Закрыть"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Right"
                Background="{DynamicResource ButtonBackgroundBrush}"
                Foreground="{DynamicResource SecondaryTextBrush}"
                BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                CornerRadius="6" Padding="14,8" Cursor="Hand" Margin="0,12,0,0"/>

        <!-- Not authenticated -->
        <StackPanel DockPanel.Dock="Top"
                    IsVisible="{Binding !IsAuthenticated}"
                    HorizontalAlignment="Center" Margin="0,30,0,0" Spacing="8">
            <TextBlock Text="🔒" FontSize="36" HorizontalAlignment="Center"/>
            <TextBlock Text="Войдите в аккаунт для управления общим доступом"
                       FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" IsVisible="{Binding IsAuthenticated}" Spacing="0">

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="#EF4444" FontSize="12" Margin="0,0,0,8"/>

            <!-- Add share -->
            <TextBlock Text="Поделиться с другом:" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6"/>

            <StackPanel IsVisible="{Binding !HasFriends}" Margin="0,0,0,12">
                <TextBlock Text="Нет друзей для добавления. Добавьте друзей в разделе 👥 Друзья."
                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Grid ColumnDefinitions="*, Auto, Auto" IsVisible="{Binding HasFriends}" Margin="0,0,0,16">
                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AvailableFriends}"
                          SelectedItem="{Binding SelectedFriend}"
                          Background="{DynamicResource InputBackgroundBrush}"
                          FontSize="13" Padding="8,6">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Username}" FontSize="13"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Permissions}"
                          SelectedItem="{Binding SelectedPermission}"
                          Width="80" Margin="6,0"
                          FontSize="12"
                          Background="{DynamicResource InputBackgroundBrush}"/>
                <Button Grid.Column="2"
                        Content="Открыть"
                        Command="{Binding ShareWithCommand}"
                        Background="{DynamicResource AccentBackground}" Foreground="White"
                        BorderThickness="0" CornerRadius="6" Padding="12,8"
                        FontSize="13" Cursor="Hand"/>
            </Grid>

            <!-- Divider -->
            <Border Background="{DynamicResource BorderBrush}" Height="1" Margin="0,0,0,12"/>

            <!-- Current shares -->
            <TextBlock Text="Текущий доступ:" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>

            <TextBlock Text="Вы ещё не открыли доступ ни одному другу."
                       IsVisible="{Binding !HasShares}"
                       FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>

            <ScrollViewer IsVisible="{Binding HasShares}" MaxHeight="200"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding MyShares}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" CornerRadius="8" Margin="0,3"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid ColumnDefinitions="*, Auto, Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{Binding SharedWithProfile.Username}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding SharedWithProfile.Email}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock FontSize="11">
                                            <Run Text="Режим: "/>
                                            <Run Text="{Binding Permission}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Сменить режим"
                                            Command="{Binding $parent[ItemsControl].((vm:CalendarShareViewModel)DataContext).TogglePermissionCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{DynamicResource ButtonBackgroundBrush}"
                                            Foreground="{DynamicResource SecondaryTextBrush}"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1"
                                            CornerRadius="5" Padding="8,4" FontSize="11"
                                            Cursor="Hand" Margin="0,0,6,0"/>
                                    <Button Grid.Column="2"
                                            Content="Закрыть доступ"
                                            Command="{Binding $parent[ItemsControl].((vm:CalendarShareViewModel)DataContext).RevokeCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="#EF4444"
                                            BorderBrush="#EF4444" BorderThickness="1"
                                            CornerRadius="5" Padding="8,4" FontSize="11" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </StackPanel>

    </DockPanel>
</Window>
