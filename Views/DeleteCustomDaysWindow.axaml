<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FocusFlowFinal.Views"
        x:Class="FocusFlowFinal.Views.DeleteCustomDaysWindow"
        x:CompileBindings="False"
        Title="Выбор дней для освобождения"
        Width="360" Height="440"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBackgroundBrush}"
        CanResize="False">

    <Window.Styles>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
        </Style>
        <Style Selector="ListBoxItem TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*, Auto" Margin="15">

        <ListBox x:Name="DateListBox"
                 Grid.Row="0"
                 SelectionMode="Multiple, Toggle"
                 Background="{DynamicResource CardBackgroundBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 BorderThickness="1"
                 CornerRadius="6"
                 Padding="4">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayText}"
                               Margin="8,6"
                               FontWeight="Medium"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,15,0,0">
            <Button x:Name="BtnCancel"
                    Content="Отмена"
                    Padding="16,6"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    CornerRadius="4"/>
            <Button x:Name="BtnConfirm"
                    Content="Применить"
                    Padding="16,6"
                    Background="{DynamicResource PrimaryActionBrush}"
                    Foreground="White"
                    FontWeight="Bold"
                    CornerRadius="4"
                    BorderThickness="0"/>
        </StackPanel>

    </Grid>
</Window>
