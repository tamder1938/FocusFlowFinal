<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        xmlns:services="clr-namespace:FocusFlowFinal.Services"
        x:Class="FocusFlowFinal.Views.AnalyticsWindow"
        x:DataType="vm:AnalyticsViewModel"
        Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AnalyticsTitle]}"
        Width="520" Height="680"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<Window.Styles>
		<Style Selector="Border.StatCard">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="14,12"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BoxShadow" Value="0 2 4 0 #03000000"/>
			<Setter Property="MinWidth" Value="100"/>
		</Style>
		<Style Selector="TextBlock.CardHeader">
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>
		<Style Selector="TextBlock.CardValue">
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="55, *, 65">

		<Border Grid.Row="0" Background="#2563EB" Padding="16,0">
			<Grid ColumnDefinitions="Auto, *, Auto">
				<StackPanel Grid.Column="0" VerticalAlignment="Center">
					<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AnalyticsTitle]}" FontSize="15" FontWeight="Bold" Foreground="White"/>
					<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AnalyticsSubtitle]}" FontSize="10" Foreground="#93C5FD"/>
				</StackPanel>
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
					<Button Content="&lt;" Command="{Binding PreviousWeekCommand}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource ButtonForegroundBrush}" Padding="10,4" CornerRadius="4"/>
					<TextBlock Text="{Binding WeekTitle}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0"/>
					<Button Content="&gt;" Command="{Binding NextWeekCommand}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource ButtonForegroundBrush}" Padding="10,4" CornerRadius="4"/>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<StackPanel Spacing="16" Margin="16">

				<UniformGrid Columns="3" Rows="1">
					<Border Classes="StatCard" Margin="0,0,4,0" ClipToBounds="True">
						<StackPanel>
							<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FocusedTotal]}" Classes="CardHeader"/>
							<TextBlock Text="{Binding TotalFocusedTimeStr}" Classes="CardValue" Margin="0,0,0,6"/>
							<TextBlock Text="{Binding WeekComparisonStr}" Foreground="{Binding WeekComparisonColor}" FontSize="11" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>

					<Border Classes="StatCard" Margin="4,0,4,0" ClipToBounds="True">
						<StackPanel>
							<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TasksCompleted]}" Classes="CardHeader"/>
							<TextBlock Text="{Binding CompletedTasksRatio}" Classes="CardValue" Margin="0,0,0,8"/>
							<Grid Margin="12,4,12,0">
								<ProgressBar Value="{Binding TasksProgressPercentage}" Height="5" Minimum="0" Maximum="100"
                                             HorizontalAlignment="Stretch"
                                             Background="{DynamicResource ProgressBackgroundBrush}"
                                             Foreground="#3B82F6" CornerRadius="2"/>
							</Grid>
						</StackPanel>
					</Border>

					<Border Classes="StatCard" Margin="4,0,0,0" ClipToBounds="True">
						<StackPanel>
							<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Productivity]}" Classes="CardHeader"/>
							<TextBlock Text="{Binding ProductivityPercentage, StringFormat='{}{0}%'}" Classes="CardValue"
                                       Foreground="{Binding ProductivityColor}" Margin="0,0,0,4"/>
							<TextBlock Text="{Binding ProductivityLevel}" Foreground="{Binding ProductivityColor}" FontSize="11" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>
				</UniformGrid>

				<Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" BoxShadow="0 2 4 0 #03000000">
					<StackPanel>
						<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FocusDistributionWeek]}" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>
						<ItemsControl ItemsSource="{Binding WeekDaysChart}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Columns="7" Rows="1" Height="180" VerticalAlignment="Bottom"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid RowDefinitions="*, Auto, Auto" Margin="4,0">
										<Border Grid.Row="0" Width="24" Height="{Binding HeightRatio}" Background="{Binding Color}" CornerRadius="4" VerticalAlignment="Bottom"/>
										<TextBlock Grid.Row="1" Text="{Binding Hours, StringFormat='{}{0}ч'}" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,2"/>
										<TextBlock Grid.Row="2" Text="{Binding DayName}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Border>

				<Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,14"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" BoxShadow="0 2 4 0 #03000000">
					<StackPanel>
						<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ProjectFocusCategories]}" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,14"/>
						<ItemsControl ItemsSource="{Binding Segments}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid ColumnDefinitions="90, *, 70" Margin="0,6">
										<TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										<ProgressBar Grid.Column="1" Value="{Binding Percentage}" Height="8"
                                                     Background="{DynamicResource ProgressBackgroundBrush}"
                                                     Foreground="{Binding Color}" CornerRadius="4" VerticalAlignment="Center" Margin="10,0"/>
										<TextBlock Grid.Column="2" Text="{Binding TimeFormatted}" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>

		<Border Grid.Row="2" Background="{DynamicResource CardSecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,0">
			<Button Content="Готово" Command="{Binding CloseWindowCommand}" CommandParameter="{Binding $parent[Window]}"
                    Width="120" Height="36" HorizontalAlignment="Right" VerticalAlignment="Center"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Background="#2563EB" Foreground="White" FontWeight="Bold" CornerRadius="6"/>
		</Border>
	</Grid>
</Window>