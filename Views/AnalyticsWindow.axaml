<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        xmlns:services="clr-namespace:FocusFlowFinal.Services"
        x:Class="FocusFlowFinal.Views.AnalyticsWindow"
        x:DataType="vm:AnalyticsViewModel"
        Title="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AnalyticsTitle]}"
        Width="540" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<Window.Styles>
		<Style Selector="Border.StatCard">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="14,12"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="MinWidth" Value="100"/>
		</Style>
		<Style Selector="TextBlock.CardHeader">
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="FontWeight" Value="Medium"/>
			<Setter Property="Margin" Value="0,0,0,4"/>
		</Style>
		<Style Selector="TextBlock.CardValue">
			<Setter Property="FontSize" Value="20"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
		</Style>
		<Style Selector="Border.SectionCard">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="16,14"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style Selector="Button.done-btn">
			<Setter Property="Background"      Value="{DynamicResource PrimaryActionBrush}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="8"/>
			<Setter Property="FontWeight"      Value="Bold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.done-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource PrimaryActionHoverBrush}"/>
		</Style>
		<Style Selector="Button.week-nav">
			<Setter Property="Background"      Value="#3B82F6"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="10,4"/>
			<Setter Property="MinWidth"        Value="32"/>
			<Setter Property="FontWeight"      Value="Bold"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.week-nav:pointerover">
			<Setter Property="Background" Value="#2563EB"/>
		</Style>
		<Style Selector="Button.tab-nav">
			<Setter Property="Background"      Value="#FFFFFF22"/>
			<Setter Property="Foreground"      Value="#C7D2FE"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="10,4"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="FontWeight"      Value="Medium"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.tab-nav.active">
			<Setter Property="Background" Value="#FFFFFF44"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="Button.tab-nav:pointerover">
			<Setter Property="Background" Value="#FFFFFF33"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="60, *, 65">

		<!-- Шапка: градиент синий → индиго -->
		<Border Grid.Row="0" Padding="18,0">
			<Border.Background>
				<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
					<GradientStop Color="#3B5BDB" Offset="0"/>
					<GradientStop Color="#4F6EF5" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Grid ColumnDefinitions="Auto, *, Auto">
				<StackPanel Grid.Column="0" VerticalAlignment="Center">
					<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[AnalyticsTitle]}"
                               FontSize="16" FontWeight="Bold" Foreground="White"/>
					<StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
						<Button Classes="tab-nav active"
                                Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[YearSummary_TabWeek]}"/>
						<Button Classes="tab-nav"
                                Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[YearSummary_TabYear]}"
                                Command="{Binding OpenYearSummaryCommand}"
                                CommandParameter="{Binding $parent[Window]}"/>
					</StackPanel>
				</StackPanel>
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
					<Button Classes="week-nav" Content="‹"
                            Background="#3B82F6" Foreground="White"
                            Command="{Binding PreviousWeekCommand}"
                            ToolTip.Tip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[PrevWeekTip]}"/>
					<TextBlock Text="{Binding WeekTitle}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="6,0"/>
					<Button Classes="week-nav" Content="›"
                            Background="#3B82F6" Foreground="White"
                            Command="{Binding NextWeekCommand}"
                            ToolTip.Tip="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[NextWeekTip]}"/>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<StackPanel Spacing="16" Margin="18">

				<!-- Карточки статистики -->
				<UniformGrid Columns="3" Rows="1">
					<Border Classes="StatCard" Margin="0,0,5,0">
						<StackPanel>
							<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FocusedTotal]}" Classes="CardHeader"/>
							<TextBlock Text="{Binding TotalFocusedTimeStr}" Classes="CardValue" Margin="0,0,0,6"/>
							<TextBlock Text="{Binding WeekComparisonStr}" Foreground="{Binding WeekComparisonColor}" FontSize="11" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>

					<Border Classes="StatCard" Margin="5,0,5,0">
						<StackPanel>
							<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[TasksCompleted]}" Classes="CardHeader"/>
							<TextBlock Text="{Binding CompletedTasksRatio}" Classes="CardValue" Margin="0,0,0,6"/>
							<TextBlock Text="{Binding TasksProgressLabel}" Foreground="{DynamicResource AccentTextBrush}" FontSize="11" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>

					<Border Classes="StatCard" Margin="5,0,0,0">
						<StackPanel>
							<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DeviationLabel]}" Classes="CardHeader"/>
							<TextBlock Text="{Binding DeviationStr}" Classes="CardValue"
                                       Foreground="{Binding DeviationColor}" Margin="0,0,0,6"/>
							<TextBlock Text="{Binding DeviationSubLabel}" Foreground="{Binding DeviationColor}" FontSize="11" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>
				</UniformGrid>

				<!-- Распределение фокуса по дням недели -->
				<Border Classes="SectionCard">
					<StackPanel>
						<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[FocusDistributionWeek]}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>
						<ItemsControl ItemsSource="{Binding WeekDaysChart}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<UniformGrid Columns="7" Rows="1" Height="180" VerticalAlignment="Bottom"/>
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid RowDefinitions="*, Auto, Auto" Margin="4,0">
										<Border Grid.Row="0" Width="24" Height="{Binding HeightRatio}"
                                                Background="{Binding Color}" CornerRadius="4" VerticalAlignment="Bottom"/>
										<TextBlock Grid.Row="1" Text="{Binding Hours, StringFormat='{}{0}ч'}" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,2"/>
										<TextBlock Grid.Row="2" Text="{Binding DayName}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Border>

				<!-- Фокус по категориям проектов -->
				<Border Classes="SectionCard">
					<StackPanel>
						<TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[ProjectFocusCategories]}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,14"/>
						<ItemsControl ItemsSource="{Binding Segments}">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Grid ColumnDefinitions="90, *, 70" Margin="0,6">
										<TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12" FontWeight="Medium"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										<ProgressBar Grid.Column="1" Value="{Binding Percentage}" Height="8"
                                                     Background="{DynamicResource ProgressBackgroundBrush}"
                                                     Foreground="{Binding Color}" CornerRadius="4" VerticalAlignment="Center" Margin="10,0"/>
										<TextBlock Grid.Column="2" Text="{Binding TimeFormatted}" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
									</Grid>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>

		<!-- Нижняя панель -->
		<Border Grid.Row="2" Background="{DynamicResource CardSecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,0">
			<Button Classes="done-btn"
                    Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[DoneBtn]}"
                    Command="{Binding CloseWindowCommand}" CommandParameter="{Binding $parent[Window]}"
                    Width="120" Height="38" HorizontalAlignment="Right" VerticalAlignment="Center"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
		</Border>
	</Grid>
</Window>
