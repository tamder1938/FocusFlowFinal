<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FocusFlowFinal.ViewModels"
        x:Class="FocusFlowFinal.Views.PostPurchaseDialog"
        x:DataType="vm:PostPurchaseViewModel"
        Title="FocusFlow"
        Width="380" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource WindowBackgroundBrush}">

	<Window.Styles>
		<Style Selector="Button.primary">
			<Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
		</Style>
		<Style Selector="Button.secondary">
			<Setter Property="Background" Value="{DynamicResource SecondaryActionBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryActionFgBrush}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
		</Style>
		<Style Selector="Button.link">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
	</Window.Styles>

	<StackPanel Margin="28" Spacing="14" VerticalAlignment="Center">

		<TextBlock Text="🎉" FontSize="36" HorizontalAlignment="Center"/>

		<TextBlock Text="{Binding Loc[PostPurchaseTitle]}"
                   FontSize="17" FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   HorizontalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center"/>

		<TextBlock Text="{Binding Loc[PostPurchaseText]}"
                   FontSize="13"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   HorizontalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center" Margin="0,0,0,10"/>

		<Button Classes="primary" Content="{Binding Loc[CreateAccountBtn]}"
                Command="{Binding CreateAccountCommand}"/>

		<Button Classes="secondary" Content="{Binding Loc[AlreadyHaveAccountBtn]}"
                Command="{Binding SignInCommand}"/>

		<Button Classes="link" Content="{Binding Loc[Close]}"
                Command="{Binding CloseCommand}"/>

	</StackPanel>
</Window>
