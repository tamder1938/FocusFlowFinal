<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        x:Class="FocusFlowFinal.Views.SettingsWindow"
        x:Name="RootWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Настройки"
        Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SettingsWindowBackground}"
        Loaded="OnLoaded">

	<Window.Styles>
		<Style Selector="Border.Card">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
			<Setter Property="Background" Value="{DynamicResource CardBackground}"/>
			<Setter Property="Padding" Value="16"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
		</Style>

		<Style Selector="Button.SideNavButton">
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="12,8"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="Background" Value="{DynamicResource SideNavButtonBackground}"/>
			<Setter Property="Foreground" Value="{DynamicResource SideNavButtonForeground}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
		<Style Selector="Button.SideNavButton:pointerover">
			<Setter Property="Background" Value="{DynamicResource SideNavButtonHoverBackground}"/>
		</Style>
		<Style Selector="Button.SideNavButton.active">
			<Setter Property="Background" Value="{DynamicResource SideNavButtonActiveBackground}"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<Style Selector="Border.HotkeyBadge">
			<Setter Property="Background" Value="{DynamicResource HotkeyBadgeBackground}"/>
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="Padding" Value="6,2"/>
			<Setter Property="BorderBrush" Value="{DynamicResource HotkeyBadgeBorder}"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="*, Auto">
		<Grid Grid.Row="0" ColumnDefinitions="250, *">
			<Border Grid.Column="0" Background="{DynamicResource SidePanelBackground}" Padding="16">
				<StackPanel>
					<TextBlock Text="Настройки" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource HeaderForeground}" Margin="0,0,0,24"/>
					<StackPanel>
						<Button x:Name="GeneralButton" Content="Общие" Classes="SideNavButton"
                                Command="{Binding SelectTabCommand}" CommandParameter="General"/>
						<Button x:Name="NotificationsButton" Content="Уведомления" Classes="SideNavButton"
                                Command="{Binding SelectTabCommand}" CommandParameter="Notifications"/>
						<Button x:Name="HotkeysButton" Content="Горячие клавиши" Classes="SideNavButton"
                                Command="{Binding SelectTabCommand}" CommandParameter="Hotkeys"/>
						<Button x:Name="DataButton" Content="Данные" Classes="SideNavButton"
                                Command="{Binding SelectTabCommand}" CommandParameter="Data"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Grid.Column="1" Background="{DynamicResource SettingsWindowBackground}" Padding="20">
				<DockPanel>
					<TextBlock DockPanel.Dock="Top" Text="Настройки" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource HeaderForeground}" Margin="0,0,0,16"/>

					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel>
							<!-- Вкладка "Общие" -->
							<StackPanel IsVisible="{Binding IsGeneralTab}">
								<Border Classes="Card">
									<StackPanel Spacing="12">
										<TextBlock Text="Внешний вид" FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
										<StackPanel Orientation="Horizontal" Spacing="8">
											<Button x:Name="LightThemeButton" Content="Светлая"
                                                    Command="{Binding SetThemeCommand}" CommandParameter="0"
                                                    Background="{DynamicResource ButtonBackground}"
                                                    Foreground="{DynamicResource ButtonForeground}"/>
											<Button x:Name="DarkThemeButton" Content="Тёмная"
                                                    Command="{Binding SetThemeCommand}" CommandParameter="1"
                                                    Background="{DynamicResource ButtonBackground}"
                                                    Foreground="{DynamicResource ButtonForeground}"/>
											<Button x:Name="AutoThemeButton" Content="Авто"
                                                    Command="{Binding SetThemeCommand}" CommandParameter="2"
                                                    Background="{DynamicResource ButtonBackground}"
                                                    Foreground="{DynamicResource ButtonForeground}"/>
										</StackPanel>
									</StackPanel>
								</Border>

								<Border Classes="Card">
									<StackPanel Spacing="12">
										<TextBlock Text="Язык и регион" FontSize="14" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryText}"/>
										<ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"
                                                  Background="{DynamicResource ComboBoxBackground}"
                                                  Foreground="{DynamicResource PrimaryText}"/>
									</StackPanel>
								</Border>
							</StackPanel>

							<!-- Остальные вкладки без изменений -->
							<!-- ... -->
						</StackPanel>
					</ScrollViewer>
				</DockPanel>
			</Border>
		</Grid>

		<Border Grid.Row="1" Background="{DynamicResource CardSecondaryBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16">
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
				<Button Content="Закрыть" Command="{Binding CancelCommand}"
                        Background="{DynamicResource ButtonBackground}"
                        Foreground="{DynamicResource ButtonForeground}" Padding="16,8" CornerRadius="4"/>
				<Button Content="Сохранить" Command="{Binding SaveCommand}"
                        Background="{DynamicResource AccentBackground}" Foreground="White" Padding="16,8" CornerRadius="4" FontWeight="Bold"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>