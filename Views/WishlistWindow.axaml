<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
        xmlns:views="clr-namespace:FocusFlowFinal.Views"
        x:Class="FocusFlowFinal.Views.WishlistWindow"
        x:DataType="vm:WishlistListViewModel"
        Title="Вишлисты"
        Width="640" Height="520"
        WindowStartupLocation="CenterOwner"
