<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:FocusFlowFinal.Converters"
        x:Class="FocusFlowFinal.Views.AddExerciseDialog"
        x:CompileBindings="False"
        Title="Новое упражнение"
        Width="520" Height="640"
        MinWidth="460" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Border Padding="20">
        <Grid RowDefinitions="*,Auto">
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">

                    <!-- Название -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Название *" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding Name}" Watermark="Например: Жим лёжа"
                                 Background="{DynamicResource CardBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 CornerRadius="8" Padding="10,8"/>
                    </StackPanel>

                    <!-- Тип упражнения -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Тип" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" x:Name="TypeBtnPanel">
                            <Button Content="Силовое"    Classes="type-btn" Tag="0" Click="TypeBtn_Click"/>
                            <Button Content="Кардио"     Classes="type-btn" Tag="1" Click="TypeBtn_Click"/>
                            <Button Content="Растяжка"   Classes="type-btn" Tag="2" Click="TypeBtn_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Основные мышцы -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Основные мышцы" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <ItemsControl ItemsSource="{Binding PrimaryMuscleItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,4,4" CornerRadius="8"
                                            Cursor="Hand"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            Background="{Binding IsSelected, Converter={x:Static conv:BoolToChipBrushConverter.Instance}}"
                                            Tapped="PrimaryMuscleChip_Tapped">
                                        <TextBlock Text="{Binding Label}"
                                                   Padding="10,5" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Вспомогательные мышцы -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Вспомогательные мышцы" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <ItemsControl ItemsSource="{Binding SecondaryMuscleItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,4,4" CornerRadius="8"
                                            Cursor="Hand"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            Background="{Binding IsSelected, Converter={x:Static conv:BoolToChipBrushConverter.Instance}}"
                                            Tapped="SecMuscleChip_Tapped">
                                        <TextBlock Text="{Binding Label}"
                                                   Padding="10,5" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Оборудование -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Оборудование" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <ItemsControl ItemsSource="{Binding EquipmentItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,4,4" CornerRadius="8"
                                            Cursor="Hand"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            Background="{Binding IsSelected, Converter={x:Static conv:BoolToChipBrushConverter.Instance}}"
                                            Tapped="EquipmentChip_Tapped">
                                        <TextBlock Text="{Binding Label}"
                                                   Padding="10,5" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Описание -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Описание / Техника" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding Description}"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="70"
                                 Background="{DynamicResource CardBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 CornerRadius="8" Padding="10,8"
                                 Watermark="Опишите технику выполнения…"/>
                    </StackPanel>

                    <!-- Эмодзи + картинка -->
                    <Grid ColumnDefinitions="Auto,*">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                            <TextBlock Text="Иконка (emoji)" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding ImageEmoji}" Width="72"
                                     Background="{DynamicResource CardBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     CornerRadius="8" Padding="10,8"
                                     FontSize="20" TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Картинка (путь или URL)" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding ImagePath}"
                                         Watermark="Необязательно"
                                         Background="{DynamicResource CardBackgroundBrush}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         CornerRadius="8" Padding="10,8"/>
                                <Button Grid.Column="1" Content="📂"
                                        Command="{Binding PickImageCommand}"
                                        Margin="6,0,0,0"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="10,8" FontSize="16"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Ошибка -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               IsVisible="{Binding ErrorMessage}"
                               Foreground="#DC4F4F" FontSize="12"/>

                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Content="Отмена"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        CornerRadius="8" Padding="16,9"/>
                <Button Grid.Column="2"
                        Command="{Binding SaveCommand}"
                        Content="Сохранить"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" CornerRadius="8" Padding="18,9"/>
            </Grid>
        </Grid>
    </Border>

    <Window.Styles>
        <Style Selector="Button.type-btn">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style Selector="Button.type-btn-active">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </Window.Styles>
</Window>
