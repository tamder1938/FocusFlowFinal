<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:FocusFlowFinal.Converters"
        x:Class="FocusFlowFinal.Views.WorkoutWindow"
        x:CompileBindings="False"
        x:Name="WndRoot"
        Title="Тренировки"
        Width="1200" Height="820"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid ColumnDefinitions="280,*,300">

        <!-- ════════════════════════════════════════════════════
             ЛЕВАЯ КОЛОНКА — вкладки: Программы / История
        ════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">

                <!-- Вкладки левой колонки -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="0"
                            Background="{DynamicResource WindowBackgroundBrush}">
                    <Button x:Name="LeftTabPrograms"
                            Content="Программы"
                            Tag="0" Click="LeftTab_Click"
                            Classes="left-tab"/>
                    <Button x:Name="LeftTabHistory"
                            Content="История"
                            Tag="1" Click="LeftTab_Click"
                            Classes="left-tab"/>
                </StackPanel>

                <!-- ── Панель: Программы ────────────────────────────────── -->
                <Grid x:Name="PanelPrograms" Grid.Row="1" RowDefinitions="Auto,*">

                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                          Margin="10,10,10,6">
                        <TextBlock Grid.Column="0"
                                   Text="Мои программы"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Command="{Binding ProgramListVm.AddProgramCommand}"
                                Content="+ Новая"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" CornerRadius="8"
                                Padding="10,5" FontSize="12"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,0,8,8">

                            <StackPanel IsVisible="{Binding !ProgramListVm.Programs.Count}"
                                        Margin="8,32" Spacing="8"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="🏋️" FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Нет программ" FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <Button Command="{Binding ProgramListVm.AddProgramCommand}"
                                        Content="Создать первую"
                                        HorizontalAlignment="Center"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource AccentBrush}"
                                        CornerRadius="8" Padding="14,7" FontSize="12"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding ProgramListVm.Programs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" CornerRadius="10"
                                                BorderThickness="2" Cursor="Hand"
                                                Tapped="ProgramCard_Tapped">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="{DynamicResource BorderBrush}"/>
                                            </Border.BorderBrush>
                                            <Border.Background>
                                                <SolidColorBrush Color="{DynamicResource WindowBackgroundBrush}"/>
                                            </Border.Background>
                                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,10">
                                                <Border Grid.Column="0"
                                                        Width="40" Height="40" CornerRadius="10"
                                                        Background="{Binding Color}"
                                                        Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding Icon}" FontSize="18"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="13" FontWeight="Medium"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="110"/>
                                                        <Border IsVisible="{Binding IsActive}"
                                                                Background="#1A10B981"
                                                                CornerRadius="4" Padding="5,2">
                                                            <TextBlock Text="✓" FontSize="10"
                                                                       Foreground="#10B981"
                                                                       FontWeight="Medium"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DaysLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                            Spacing="0" VerticalAlignment="Center">
                                                    <Button Content="✏️"
                                                            Command="{Binding DataContext.ProgramListVm.EditProgramCommand, ElementName=WndRoot}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="4" FontSize="12"
                                                            ToolTip.Tip="Редактировать"/>
                                                    <Button Content="🗑"
                                                            Command="{Binding DataContext.ProgramListVm.DeleteProgramCommand, ElementName=WndRoot}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Padding="4" FontSize="12"
                                                            ToolTip.Tip="Удалить"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- ── Панель: История ──────────────────────────────────── -->
                <Grid x:Name="PanelHistory" Grid.Row="1" RowDefinitions="Auto,*"
                      IsVisible="False">

                    <!-- Сводная статистика -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            CornerRadius="10" Margin="8,8,8,4" Padding="10,10">
                        <Grid ColumnDefinitions="*,*,*">
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="1">
                                <TextBlock Text="{Binding HistoryVm.TotalSessions}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="сессий" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="1">
                                <TextBlock Text="{Binding HistoryVm.TotalTonnageLabel}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="тоннаж" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="1">
                                <TextBlock Text="{Binding HistoryVm.TotalDurationLabel}"
                                           FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="время" FontSize="10"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,0,8,8">

                            <!-- Пусто -->
                            <StackPanel IsVisible="{Binding HistoryVm.IsEmpty}"
                                        Margin="8,40" Spacing="8"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="🗒️" FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Тренировок пока нет" FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Начните первую сессию!" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Карточки сессий -->
                            <ItemsControl ItemsSource="{Binding HistoryVm.Sessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" CornerRadius="10"
                                                Background="{DynamicResource WindowBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel>

                                                <!-- Шапка карточки -->
                                                <Border Padding="10,10,10,8"
                                                        Cursor="Hand"
                                                        Tapped="HistoryCard_Tapped">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <!-- Лево: дата/день/подходы -->
                                                        <StackPanel Grid.Column="0" Spacing="2">
                                                            <TextBlock Text="{Binding DateLabel}"
                                                                       FontSize="12" FontWeight="Medium"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                            <TextBlock Text="{Binding DayLabel}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SetsLabel}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        </StackPanel>
                                                        <!-- Право: длительность/тоннаж/стрелка -->
                                                        <StackPanel Grid.Column="1"
                                                                    HorizontalAlignment="Right"
                                                                    Spacing="2">
                                                            <TextBlock Text="{Binding DurationLabel}"
                                                                       FontSize="12" FontWeight="Medium"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding TonnageLabel}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       HorizontalAlignment="Right"/>
                                                            <StackPanel HorizontalAlignment="Right">
                                                                <TextBlock Text="▲" IsVisible="{Binding IsExpanded}"
                                                                           FontSize="9"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                                <TextBlock Text="▼" IsVisible="{Binding !IsExpanded}"
                                                                           FontSize="9"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Развёрнутый блок: упражнения -->
                                                <StackPanel IsVisible="{Binding IsExpanded}">
                                                    <Border Height="1"
                                                            Background="{DynamicResource BorderBrush}"
                                                            Margin="10,0"/>

                                                    <StackPanel Margin="10,8,10,4" Spacing="6">
                                                        <ItemsControl ItemsSource="{Binding Exercises}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Margin="0,0,0,4"
                                                                                Spacing="1">
                                                                        <TextBlock Text="{Binding ExerciseName}"
                                                                                   FontSize="12"
                                                                                   FontWeight="Medium"
                                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                                        <TextBlock Text="{Binding SetsCompact}"
                                                                                   FontSize="11"
                                                                                   FontFamily="Consolas"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <!-- Кнопка удалить -->
                                                    <Border Padding="10,0,10,10">
                                                        <Button Content="🗑 Удалить сессию"
                                                                Command="{Binding DeleteCommand}"
                                                                Background="Transparent"
                                                                BorderBrush="#3AEF4444"
                                                                BorderThickness="1"
                                                                Foreground="#EF4444"
                                                                CornerRadius="8"
                                                                Padding="10,6" FontSize="11"
                                                                HorizontalAlignment="Left"/>
                                                    </Border>
                                                </StackPanel>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════
             ЦЕНТРАЛЬНАЯ КОЛОНКА
        ════════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid>

                <!-- 1. Нет выбранной программы -->
                <StackPanel IsVisible="{Binding ShowProgramPlaceholder}"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="12">
                    <TextBlock Text="🏋️" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите программу слева" FontSize="16"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="или создайте новую" FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 2. Детали программы -->
                <Grid IsVisible="{Binding ShowProgramDetail}"
                      DataContext="{Binding ProgramListVm.SelectedProgram}"
                      RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="20,16">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="14"
                                    Background="{Binding Color}" Margin="0,0,14,0">
                                <TextBlock Text="{Binding Icon}" FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding DaysLabel}" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <Border IsVisible="{Binding IsActive}"
                                            Background="#1A10B981" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="✓ Активная" FontSize="11"
                                                   Foreground="#10B981" FontWeight="Medium"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Notes}" IsVisible="{Binding Notes}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="⭐ Сделать активной"
                                    IsVisible="{Binding !IsActive}"
                                    Command="{Binding DataContext.ProgramListVm.SetActiveProgramCommand, ElementName=WndRoot}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    CornerRadius="8" Padding="12,7" FontSize="12"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="20,16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Дни тренировок"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Days}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="12"
                                                Padding="16,14">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <Border Grid.Column="0" Width="36" Height="36"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding DayNumber}"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="3"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14" FontWeight="Medium"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    <TextBlock Text="{Binding MusclesLabel}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                    <TextBlock Text="{Binding ExerciseCountLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Content="▶ Начать"
                                                        Command="{Binding DataContext.StartSessionCommand, ElementName=WndRoot}"
                                                        CommandParameter="{Binding}"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Foreground="White"
                                                        CornerRadius="8" Padding="12,7"
                                                        FontSize="12" FontWeight="Medium"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <StackPanel IsVisible="{Binding !Days.Count}"
                                        HorizontalAlignment="Center" Spacing="6" Margin="0,30">
                                <TextBlock Text="📅" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Дни не добавлены" FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- 3. Активная тренировка -->
                <Grid IsVisible="{Binding IsSessionActive}"
                      DataContext="{Binding ActiveSessionVm}"
                      RowDefinitions="Auto,*,Auto">

                    <!-- Шапка сессии -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="16,14">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ProgramIcon}"
                                       FontSize="28" Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DayName}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="⏱" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding ElapsedLabel}"
                                               FontSize="12" FontFamily="Consolas"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center">
                                <Button Content="Бросить"
                                        Command="{Binding AbandonCommand}"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        CornerRadius="8" Padding="10,7" FontSize="12"/>
                                <Button Content="✓ Завершить"
                                        Command="{Binding FinishCommand}"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        CornerRadius="8" Padding="12,7"
                                        FontSize="12" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Список упражнений -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="0" Margin="16,12,16,0">

                            <Border IsVisible="{Binding !Exercises.Count}"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="12"
                                    Padding="24" Margin="0,0,0,12">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="➕" FontSize="32" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Нажмите ➕ на упражнение справа"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="чтобы добавить его в тренировку"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Exercises}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="12"
                                                Padding="14,12">
                                            <StackPanel Spacing="8">

                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding ImageEmoji}"
                                                               FontSize="22"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"/>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ExerciseName}"
                                                                   FontSize="14" FontWeight="Medium"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                        <TextBlock Text="{Binding CompletedSetsLabel}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="2"
                                                            Command="{Binding ToggleExpandedCommand}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{DynamicResource SecondaryTextBrush}"
                                                            FontSize="16" Padding="6">
                                                        <StackPanel>
                                                            <TextBlock Text="▲" IsVisible="{Binding IsExpanded}"/>
                                                            <TextBlock Text="▼" IsVisible="{Binding !IsExpanded}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <StackPanel IsVisible="{Binding IsExpanded}" Spacing="4">
                                                    <ItemsControl ItemsSource="{Binding Sets}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid ColumnDefinitions="24,*,Auto,*,Auto,Auto"
                                                                      Margin="0,2">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding SetNumber}"
                                                                               FontSize="12" FontWeight="Medium"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"/>
                                                                    <NumericUpDown Grid.Column="1"
                                                                                   Value="{Binding WeightKg}"
                                                                                   Minimum="0" Maximum="999"
                                                                                   Increment="2.5"
                                                                                   FormatString="0.##"
                                                                                   Background="{DynamicResource WindowBackgroundBrush}"
                                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                                   BorderBrush="{DynamicResource BorderBrush}"
                                                                                   CornerRadius="6"
                                                                                   FontSize="13"
                                                                                   Height="34"/>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="кг"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="6,0"/>
                                                                    <NumericUpDown Grid.Column="3"
                                                                                   Value="{Binding Reps}"
                                                                                   Minimum="1" Maximum="200"
                                                                                   Increment="1"
                                                                                   FormatString="0"
                                                                                   Background="{DynamicResource WindowBackgroundBrush}"
                                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                                   BorderBrush="{DynamicResource BorderBrush}"
                                                                                   CornerRadius="6"
                                                                                   FontSize="13"
                                                                                   Height="34"/>
                                                                    <TextBlock Grid.Column="4"
                                                                               Text="повт."
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Margin="6,0"/>
                                                                    <Grid Grid.Column="5" Width="80">
                                                                        <Button IsVisible="{Binding !IsCompleted}"
                                                                                Command="{Binding CompleteCommand}"
                                                                                Background="{DynamicResource AccentBrush}"
                                                                                Foreground="White"
                                                                                CornerRadius="8"
                                                                                Padding="6,5"
                                                                                FontSize="11"
                                                                                Content="Готово"
                                                                                HorizontalAlignment="Stretch"
                                                                                HorizontalContentAlignment="Center"/>
                                                                        <Border IsVisible="{Binding IsCompleted}"
                                                                                Background="#1A10B981"
                                                                                CornerRadius="8"
                                                                                Padding="6,5">
                                                                            <TextBlock Text="✓ Готово"
                                                                                       FontSize="11"
                                                                                       Foreground="#10B981"
                                                                                       FontWeight="Medium"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6" Margin="0,4,0,0">
                                                        <Button Content="+ Подход"
                                                                Command="{Binding AddSetCommand}"
                                                                Background="Transparent"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                Foreground="{DynamicResource AccentBrush}"
                                                                CornerRadius="8" Padding="10,5"
                                                                FontSize="12"/>
                                                        <Button Content="✕"
                                                                Command="{Binding RemoveLastSetCommand}"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                                Padding="6,5" FontSize="13"
                                                                ToolTip.Tip="Удалить последний подход"/>
                                                    </StackPanel>
                                                </StackPanel>

                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Таймер отдыха -->
                    <Border Grid.Row="2"
                            IsVisible="{Binding RestTimer.IsRunning}"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="16,12">
                        <Grid RowDefinitions="Auto,Auto,Auto">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Отдых"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RestTimer.RemainingLabel}"
                                           FontSize="22" FontWeight="Bold"
                                           FontFamily="Consolas"
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Grid>
                            <ProgressBar Grid.Row="1"
                                         Value="{Binding RestTimer.Progress}"
                                         Maximum="1.0"
                                         Height="6" CornerRadius="3"
                                         Foreground="{DynamicResource AccentBrush}"
                                         Background="{DynamicResource BorderBrush}"
                                         Margin="0,0,0,10"/>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                                <Button Content="Пропустить"
                                        Command="{Binding RestTimer.SkipCommand}"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                                <Button Content="+30с"
                                        Command="{Binding RestTimer.AdjustTimeCommand}"
                                        CommandParameter="30"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                                <Button Content="−15с"
                                        Command="{Binding RestTimer.AdjustTimeCommand}"
                                        CommandParameter="-15"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource PrimaryTextBrush}"
                                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>

            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════
             ПРАВАЯ КОЛОНКА
        ════════════════════════════════════════════════════ -->
        <Border Grid.Column="2"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid RowDefinitions="Auto,*">

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="0"
                            Background="{DynamicResource WindowBackgroundBrush}">
                    <Button Content="Упражнения" Classes="right-tab"
                            Tag="0" Click="RightTab_Click" x:Name="TabExercises"/>
                    <Button Content="Аналитика"  Classes="right-tab"
                            Tag="1" Click="RightTab_Click" x:Name="TabAnalytics"/>
                    <Button Content="Уровень"    Classes="right-tab"
                            Tag="2" Click="RightTab_Click" x:Name="TabStrength"/>
                </StackPanel>

                <Grid Grid.Row="1">

                    <Grid x:Name="PanelExercises" RowDefinitions="Auto,Auto,*,Auto"
                          Margin="8,8,8,8">

                        <Border Grid.Row="0"
                                IsVisible="{Binding IsSessionActive}"
                                Background="#1A3B82F6"
                                CornerRadius="8" Padding="10,7" Margin="0,0,0,8">
                            <TextBlock Text="➕ Нажмите на упражнение, чтобы добавить в тренировку"
                                       FontSize="11"
                                       Foreground="{DynamicResource AccentBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <TextBox Grid.Row="1"
                                 Text="{Binding ExerciseListVm.SearchQuery}"
                                 Watermark="🔍 Поиск упражнений…"
                                 Background="{DynamicResource WindowBackgroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CornerRadius="8" Padding="10,7"
                                 Margin="0,0,0,6"/>

                        <Grid Grid.Row="2" RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,8">
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding ExerciseListVm.MuscleOptions}"
                                          SelectedIndex="{Binding ExerciseListVm.MuscleFilterIndex}"
                                          Margin="0,0,4,0" FontSize="12"
                                          Background="{DynamicResource WindowBackgroundBrush}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderBrush="{DynamicResource BorderBrush}"
                                          HorizontalAlignment="Stretch"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ExerciseListVm.EquipmentOptions}"
                                          SelectedIndex="{Binding ExerciseListVm.EquipmentFilterIndex}"
                                          Margin="4,0,0,0" FontSize="12"
                                          Background="{DynamicResource WindowBackgroundBrush}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          BorderBrush="{DynamicResource BorderBrush}"
                                          HorizontalAlignment="Stretch"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Упражнения не найдены"
                                               IsVisible="{Binding !ExerciseListVm.Items.Count}"
                                               Margin="12,20" FontSize="13" TextAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <ItemsControl ItemsSource="{Binding ExerciseListVm.Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,2" CornerRadius="8"
                                                        Background="{DynamicResource WindowBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1" Padding="8,6">
                                                    <Grid ColumnDefinitions="40,*,Auto">
                                                        <Border Grid.Column="0" Width="36" Height="36"
                                                                CornerRadius="8"
                                                                Background="{DynamicResource CardBackgroundBrush}">
                                                            <TextBlock Text="{Binding ImageEmoji}"
                                                                       FontSize="18"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Spacing="1"
                                                                    Margin="8,0,6,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="13" FontWeight="Medium"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       TextTrimming="CharacterEllipsis">
                                                                <Run Text="{Binding PrimaryMusclesLabel}"/>
                                                                <Run Text=" · "/>
                                                                <Run Text="{Binding EquipmentLabel}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Content="➕"
                                                                IsVisible="{Binding DataContext.IsSessionActive, ElementName=WndRoot}"
                                                                Command="{Binding DataContext.AddExerciseToSessionCommand, ElementName=WndRoot}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent"
                                                                BorderThickness="0" Padding="4"
                                                                FontSize="15"
                                                                ToolTip.Tip="Добавить в тренировку"/>
                                                        <Button Grid.Column="2"
                                                                Content="📊"
                                                                IsVisible="{Binding DataContext.IsNotSessionActive, ElementName=WndRoot}"
                                                                Command="{Binding DataContext.ExerciseListVm.ShowHistoryCommand, ElementName=WndRoot}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent"
                                                                BorderThickness="0" Padding="4"
                                                                FontSize="14"
                                                                ToolTip.Tip="История подходов"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Button Grid.Row="3"
                                IsVisible="{Binding IsNotSessionActive}"
                                Command="{Binding ExerciseListVm.AddExerciseCommand}"
                                Content="+ Своё упражнение"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" CornerRadius="8"
                                Padding="0,10" FontSize="13"/>
                    </Grid>

                    <ScrollViewer x:Name="PanelAnalytics" IsVisible="False"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,8,8,12" Spacing="10">

                            <!-- Пусто -->
                            <StackPanel IsVisible="{Binding AnalyticsVm.IsEmpty}"
                                        HorizontalAlignment="Center" Spacing="8" Margin="0,60,0,0">
                                <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Нет данных для анализа" FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Завершите хотя бы одну тренировку"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Общая статистика -->
                            <Border IsVisible="{Binding !AnalyticsVm.IsEmpty}"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="12,10">
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                    <StackPanel Grid.Column="0" Grid.Row="0"
                                                HorizontalAlignment="Center" Spacing="1" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding AnalyticsVm.TotalSessions}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="тренировок" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="0"
                                                HorizontalAlignment="Center" Spacing="1" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding AnalyticsVm.TotalTonnageLabel}"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="общий тоннаж" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="0" Grid.Row="1"
                                                HorizontalAlignment="Center" Spacing="1">
                                        <TextBlock Text="{Binding AnalyticsVm.AvgDurationLabel}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="ср. длительность" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Grid.Row="1"
                                                HorizontalAlignment="Center" Spacing="1">
                                        <TextBlock Text="{Binding AnalyticsVm.BestSessionLabel}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="110"/>
                                        <TextBlock Text="лучшая сессия" FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Тоннаж по дням — бар-чарт -->
                            <Border IsVisible="{Binding !AnalyticsVm.IsEmpty}"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="10,10,10,8">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="📊 Тоннаж — 14 дней"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <Border Height="120"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="6" ClipToBounds="True">
                                        <ItemsControl ItemsSource="{Binding AnalyticsVm.TonnageByDay}"
                                                      VerticalAlignment="Bottom" Margin="4,0,4,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Bottom"
                                                                Spacing="2"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel VerticalAlignment="Bottom" Width="16">
                                                        <Border Background="{DynamicResource AccentBrush}"
                                                                Height="{Binding BarHeight}"
                                                                CornerRadius="2,2,0,0"
                                                                ToolTip.Tip="{Binding Tooltip}"
                                                                VerticalAlignment="Bottom"/>
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="8"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,2,0,3"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Топ упражнений (горизонтальные бары) -->
                            <Border IsVisible="{Binding AnalyticsVm.TopExercises.Count}"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="10,10">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="🏆 Топ упражнений"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <ItemsControl ItemsSource="{Binding AnalyticsVm.TopExercises}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,7" Spacing="3">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding ExerciseName}"
                                                                   FontSize="12" FontWeight="Medium"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding MaxWeightLabel}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Margin="6,0,0,0"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <Border Grid.Column="0"
                                                                Height="8"
                                                                Width="{Binding BarWidth}"
                                                                Background="{DynamicResource AccentBrush}"
                                                                CornerRadius="3"
                                                                VerticalAlignment="Center"
                                                                ToolTip.Tip="{Binding TonnageLabel}"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding TonnageLabel}"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="6,0,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Выбор упражнения для графика прогресса -->
                            <Border IsVisible="{Binding !AnalyticsVm.IsEmpty}"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="10,10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="💪 Прогресс по упражнению"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <!-- График прогресса (когда выбрано) -->
                                    <StackPanel IsVisible="{Binding AnalyticsVm.HasFocusExercise}"
                                                Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding AnalyticsVm.FocusExerciseName}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="1"
                                                    Content="✕"
                                                    Command="{Binding AnalyticsVm.ClearFocusExerciseCommand}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                                    Padding="4,2" FontSize="11"/>
                                        </Grid>
                                        <TextBlock Text="макс. вес за сессию (до 10)"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Border Height="100"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                CornerRadius="6" ClipToBounds="True">
                                            <ItemsControl ItemsSource="{Binding AnalyticsVm.ExerciseProgress}"
                                                          VerticalAlignment="Bottom" Margin="4,0,4,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Bottom"
                                                                    Spacing="4"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel VerticalAlignment="Bottom" Width="22">
                                                            <Border Background="#7C3AED"
                                                                    Height="{Binding BarHeight}"
                                                                    CornerRadius="3,3,0,0"
                                                                    ToolTip.Tip="{Binding Tooltip}"
                                                                    VerticalAlignment="Bottom"/>
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="8"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,2,0,3"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>

                                    <!-- Список упражнений -->
                                    <TextBlock Text="Выберите упражнение:"
                                               FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <ItemsControl ItemsSource="{Binding AnalyticsVm.TopExercises}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,1"
                                                        Command="{Binding DataContext.AnalyticsVm.SelectExerciseCommand, ElementName=WndRoot}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Background="Transparent"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        CornerRadius="0"
                                                        Padding="2,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding ExerciseName}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="2" Margin="6,0,0,0">
                                                            <TextBlock Text="{Binding SessionCount}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                            <TextBlock Text="сес."
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer x:Name="PanelStrength" IsVisible="False"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,8,8,12" Spacing="10">

                            <!-- Пусто -->
                            <StackPanel IsVisible="{Binding StrengthVm.IsEmpty}"
                                        HorizontalAlignment="Center" Spacing="8" Margin="0,60,0,0">
                                <TextBlock Text="💪" FontSize="48" HorizontalAlignment="Center"/>
                                <TextBlock Text="Нет данных тренировок"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Завершите хотя бы одну сессию"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Вес тела -->
                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="12,10">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="Вес тела"
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <NumericUpDown Grid.Column="1"
                                                   Value="{Binding StrengthVm.BodyWeight}"
                                                   Minimum="30" Maximum="300"
                                                   Increment="0.5"
                                                   FormatString="0.#"
                                                   Width="100" Height="34"
                                                   Background="{DynamicResource CardBackgroundBrush}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   BorderBrush="{DynamicResource BorderBrush}"
                                                   CornerRadius="8" FontSize="13"/>
                                    <TextBlock Grid.Column="2"
                                               Text=" кг"
                                               FontSize="13"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Мышечный силуэт -->
                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="10,10">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding StrengthVm.WeekLabel}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <!-- Canvas — тело (вид спереди) -->
                                    <Canvas Width="130" Height="248"
                                            HorizontalAlignment="Center">

                                        <!-- Back (пики из-за груди по бокам, рисуются первыми) -->
                                        <Border Canvas.Left="22" Canvas.Top="44"
                                                Width="18" Height="44"
                                                Background="{Binding StrengthVm.BackBrush}"
                                                CornerRadius="3" Opacity="0.75"
                                                ToolTip.Tip="{Binding StrengthVm.BackHint}"/>
                                        <Border Canvas.Left="90" Canvas.Top="44"
                                                Width="18" Height="44"
                                                Background="{Binding StrengthVm.BackBrush}"
                                                CornerRadius="3" Opacity="0.75"
                                                ToolTip.Tip="{Binding StrengthVm.BackHint}"/>

                                        <!-- Ноги — бёдра -->
                                        <Border Canvas.Left="38" Canvas.Top="134"
                                                Width="54" Height="20"
                                                Background="{Binding StrengthVm.LegsBrush}"
                                                CornerRadius="3"
                                                ToolTip.Tip="{Binding StrengthVm.LegsHint}"/>
                                        <!-- Ноги — квадрицепсы -->
                                        <Border Canvas.Left="39" Canvas.Top="154"
                                                Width="25" Height="50"
                                                Background="{Binding StrengthVm.LegsBrush}"
                                                CornerRadius="4,4,2,2"
                                                ToolTip.Tip="{Binding StrengthVm.LegsHint}"/>
                                        <Border Canvas.Left="66" Canvas.Top="154"
                                                Width="25" Height="50"
                                                Background="{Binding StrengthVm.LegsBrush}"
                                                CornerRadius="4,4,2,2"
                                                ToolTip.Tip="{Binding StrengthVm.LegsHint}"/>
                                        <!-- Ноги — голени -->
                                        <Border Canvas.Left="41" Canvas.Top="206"
                                                Width="21" Height="34"
                                                Background="{Binding StrengthVm.LegsBrush}"
                                                CornerRadius="3" Opacity="0.8"
                                                ToolTip.Tip="{Binding StrengthVm.LegsHint}"/>
                                        <Border Canvas.Left="68" Canvas.Top="206"
                                                Width="21" Height="34"
                                                Background="{Binding StrengthVm.LegsBrush}"
                                                CornerRadius="3" Opacity="0.8"
                                                ToolTip.Tip="{Binding StrengthVm.LegsHint}"/>

                                        <!-- Трицепс (за бицепсом, рисуется до) -->
                                        <Border Canvas.Left="12" Canvas.Top="68"
                                                Width="16" Height="28"
                                                Background="{Binding StrengthVm.TricepsBrush}"
                                                CornerRadius="3" Opacity="0.7"
                                                ToolTip.Tip="{Binding StrengthVm.TricepsHint}"/>
                                        <Border Canvas.Left="102" Canvas.Top="68"
                                                Width="16" Height="28"
                                                Background="{Binding StrengthVm.TricepsBrush}"
                                                CornerRadius="3" Opacity="0.7"
                                                ToolTip.Tip="{Binding StrengthVm.TricepsHint}"/>

                                        <!-- Бицепс -->
                                        <Border Canvas.Left="14" Canvas.Top="64"
                                                Width="20" Height="36"
                                                Background="{Binding StrengthVm.BicepsBrush}"
                                                CornerRadius="4"
                                                ToolTip.Tip="{Binding StrengthVm.BicepsHint}"/>
                                        <Border Canvas.Left="96" Canvas.Top="64"
                                                Width="20" Height="36"
                                                Background="{Binding StrengthVm.BicepsBrush}"
                                                CornerRadius="4"
                                                ToolTip.Tip="{Binding StrengthVm.BicepsHint}"/>

                                        <!-- Предплечья (нейтральные) -->
                                        <Border Canvas.Left="16" Canvas.Top="102"
                                                Width="16" Height="26"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="3"/>
                                        <Border Canvas.Left="98" Canvas.Top="102"
                                                Width="16" Height="26"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="3"/>

                                        <!-- Грудь -->
                                        <Border Canvas.Left="38" Canvas.Top="42"
                                                Width="54" Height="44"
                                                Background="{Binding StrengthVm.ChestBrush}"
                                                CornerRadius="4"
                                                ToolTip.Tip="{Binding StrengthVm.ChestHint}"/>

                                        <!-- Плечи -->
                                        <Ellipse Canvas.Left="13" Canvas.Top="36"
                                                 Width="26" Height="22"
                                                 Fill="{Binding StrengthVm.ShouldersBrush}"
                                                 ToolTip.Tip="{Binding StrengthVm.ShouldersHint}"/>
                                        <Ellipse Canvas.Left="91" Canvas.Top="36"
                                                 Width="26" Height="22"
                                                 Fill="{Binding StrengthVm.ShouldersBrush}"
                                                 ToolTip.Tip="{Binding StrengthVm.ShouldersHint}"/>

                                        <!-- Кор/пресс (поверх груди снизу) -->
                                        <Border Canvas.Left="43" Canvas.Top="87"
                                                Width="44" Height="42"
                                                Background="{Binding StrengthVm.CoreBrush}"
                                                CornerRadius="3"
                                                ToolTip.Tip="{Binding StrengthVm.CoreHint}"/>

                                        <!-- Шея (нейтральная) -->
                                        <Border Canvas.Left="59" Canvas.Top="28"
                                                Width="12" Height="12"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"/>

                                        <!-- Голова (нейтральная) -->
                                        <Ellipse Canvas.Left="50" Canvas.Top="0"
                                                 Width="30" Height="30"
                                                 Fill="{DynamicResource CardBackgroundBrush}"
                                                 Stroke="{DynamicResource BorderBrush}"
                                                 StrokeThickness="1"/>
                                    </Canvas>

                                    <!-- Легенда мышц (2 колонки) -->
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                        <StackPanel Grid.Column="0" Grid.Row="0"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.ChestBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Грудь" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="0"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.BackBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Спина" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="0" Grid.Row="1"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.LegsBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Ноги" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="1"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.ShouldersBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Плечи" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="0" Grid.Row="2"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.BicepsBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Бицепс" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="2"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.TricepsBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Трицепс" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="0" Grid.Row="3"
                                                    Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <Ellipse Width="9" Height="9"
                                                     Fill="{Binding StrengthVm.CoreBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Кор" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Шкала цветов -->
                                        <StackPanel Grid.Column="1" Grid.Row="3"
                                                    Orientation="Horizontal" Spacing="3" Margin="0,2">
                                            <Ellipse Width="7" Height="7" Fill="#374151" VerticalAlignment="Center"/>
                                            <Ellipse Width="7" Height="7" Fill="#1E40AF" VerticalAlignment="Center"/>
                                            <Ellipse Width="7" Height="7" Fill="#3B82F6" VerticalAlignment="Center"/>
                                            <Ellipse Width="7" Height="7" Fill="#10B981" VerticalAlignment="Center"/>
                                            <TextBlock Text="↑" FontSize="9"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Ключевые подъёмы / 1RM -->
                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="10" Padding="10,10">
                                <StackPanel Spacing="10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="⚡ Расчётный 1RM"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Формула Эпли · 1RM = вес × (1 + повт/30)"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding StrengthVm.KeyLifts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Background="{DynamicResource CardBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1" CornerRadius="10"
                                                        Padding="10,10">
                                                    <StackPanel Spacing="6">

                                                        <!-- Шапка: эмодзи, название, 1RM -->
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Emoji}"
                                                                       FontSize="20"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ExerciseName}"
                                                                       FontSize="13" FontWeight="Medium"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding OneRmLabel}"
                                                                       FontSize="14" FontWeight="Bold"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>

                                                        <!-- Уровень (когда есть данные) -->
                                                        <StackPanel IsVisible="{Binding HasData}" Spacing="4">
                                                            <!-- Бейдж уровня -->
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <Border Background="{Binding LevelBrush}"
                                                                        CornerRadius="4" Padding="8,3">
                                                                    <TextBlock Text="{Binding LevelLabel}"
                                                                               FontSize="11" FontWeight="Medium"
                                                                               Foreground="White"/>
                                                                </Border>
                                                            </StackPanel>
                                                            <!-- Прогресс-бар уровня -->
                                                            <ProgressBar Value="{Binding LevelProgress}"
                                                                         Maximum="1.0"
                                                                         Height="6" CornerRadius="3"
                                                                         Foreground="{Binding LevelBrush}"
                                                                         Background="{DynamicResource BorderBrush}"/>
                                                            <!-- Подсказка: до следующего уровня -->
                                                            <TextBlock Text="{Binding NextLevelHint}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        </StackPanel>

                                                        <!-- Нет данных -->
                                                        <TextBlock IsVisible="{Binding !HasData}"
                                                                   Text="{Binding NextLevelHint}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>

                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Легенда уровней -->
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Уровни силы (% от веса тела):"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Border Background="#9CA3AF" CornerRadius="3" Padding="5,2">
                                                <TextBlock Text="Нач." FontSize="9" Foreground="White"/>
                                            </Border>
                                            <Border Background="#3B82F6" CornerRadius="3" Padding="5,2">
                                                <TextBlock Text="Нов." FontSize="9" Foreground="White"/>
                                            </Border>
                                            <Border Background="#10B981" CornerRadius="3" Padding="5,2">
                                                <TextBlock Text="Сред." FontSize="9" Foreground="White"/>
                                            </Border>
                                            <Border Background="#F59E0B" CornerRadius="3" Padding="5,2">
                                                <TextBlock Text="Прод." FontSize="9" Foreground="White"/>
                                            </Border>
                                            <Border Background="#8B5CF6" CornerRadius="3" Padding="5,2">
                                                <TextBlock Text="Элита" FontSize="9" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>
            </Grid>
        </Border>

    </Grid>

    <Window.Styles>
        <Style Selector="Button.left-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>
        <Style Selector="Button.left-tab-active">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="Button.right-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>
        <Style Selector="Button.right-tab-active">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </Window.Styles>

</Window>
