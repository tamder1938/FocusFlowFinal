<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FocusFlowFinal.ViewModels"
        x:Class="FocusFlowFinal.Views.TimerTemplateDialog"
        x:DataType="vm:TimerTemplateDialogViewModel"
        Title="Шаблон таймера"
        Width="320" Height="280"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

	<StackPanel Margin="15" Spacing="10">
		<Grid ColumnDefinitions="*, Auto">
			<TextBlock Grid.Column="0" Text="Шаблон таймера" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource HeaderForeground}"/>
			<Button Grid.Column="1" Content="✕" Command="{Binding CancelCommand}"
                    Background="Transparent" BorderThickness="0" Foreground="Gray"/>
		</Grid>

		<TextBlock Text="Имя шаблона:" FontSize="12" Foreground="Gray"/>
		<TextBox Text="{Binding Name}" Watermark="Например, Помодоро 25/5"/>

		<Grid ColumnDefinitions="Auto, *">
			<TextBlock Grid.Column="0" Text="Работа (мин):" VerticalAlignment="Center" Margin="0,0,10,0"/>
			<TextBox Grid.Column="1" Text="{Binding WorkMinutes}"/>
		</Grid>

		<Grid ColumnDefinitions="Auto, *">
			<TextBlock Grid.Column="0" Text="Пауза (мин):" VerticalAlignment="Center" Margin="0,0,10,0"/>
			<TextBox Grid.Column="1" Text="{Binding BreakMinutes}"/>
		</Grid>

		<Grid ColumnDefinitions="Auto, *">
			<TextBlock Grid.Column="0" Text="Циклов:" VerticalAlignment="Center" Margin="0,0,10,0"/>
			<TextBox Grid.Column="1" Text="{Binding Cycles}"/>
		</Grid>

		<Grid ColumnDefinitions="*, *" Margin="0,12,0,0">
			<Button Grid.Column="0" Content="Отмена" Command="{Binding CancelCommand}"
                    Margin="5" Height="36" CornerRadius="6"/>
			<Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveCommand}"
                    Margin="5" Background="{DynamicResource PrimaryActionBrush}"
                    Foreground="White" Height="36" CornerRadius="6" FontWeight="Bold"/>
		</Grid>
	</StackPanel>
</Window>
