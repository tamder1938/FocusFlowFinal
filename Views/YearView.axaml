<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FocusFlowFinal.ViewModels"
             x:Class="FocusFlowFinal.Views.YearView"
             x:DataType="vm:YearViewModel"
             x:Name="Root"
             Padding="10">

	<Grid RowDefinitions="Auto, *" Background="{DynamicResource WindowBackgroundBrush}">
		<Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="10,5,10,15">
			<Button Grid.Column="0" Content="&lt;" Command="{Binding PreviousYearCommand}" Padding="8,4"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}" CornerRadius="6"/>
			<TextBlock Grid.Column="1" Text="{Binding YearTitle}" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
			<Button Grid.Column="2" Content="&gt;" Command="{Binding NextYearCommand}" Padding="8,4"
                    Background="{DynamicResource ButtonBackgroundBrush}"
                    Foreground="{DynamicResource ButtonForegroundBrush}" CornerRadius="6"/>
		</Grid>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
			<ItemsControl ItemsSource="{Binding Months}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<UniformGrid Columns="3"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:YearMonthItem">
						<!-- Увеличен отступ между карточками -->
						<Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="12"
                                Margin="12"
                                Padding="12"
                                BoxShadow="0 2 6 0 #20000000"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
							<Grid RowDefinitions="Auto, Auto, *">
								<TextBlock Grid.Row="0" Text="{Binding MonthName}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="14" FontWeight="Bold"
                                           Margin="4,0,0,10"/>

								<Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Margin="0,0,0,6">
									<TextBlock Grid.Column="0" Text="{Binding DataContext.MonShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
									<TextBlock Grid.Column="1" Text="{Binding DataContext.TueShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
									<TextBlock Grid.Column="2" Text="{Binding DataContext.WedShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
									<TextBlock Grid.Column="3" Text="{Binding DataContext.ThuShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
									<TextBlock Grid.Column="4" Text="{Binding DataContext.FriShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
									<TextBlock Grid.Column="5" Text="{Binding DataContext.SatShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
									<TextBlock Grid.Column="6" Text="{Binding DataContext.SunShort, ElementName=Root}"
                                               FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                               HorizontalAlignment="Center" FontWeight="Medium"/>
								</Grid>

								<ItemsControl Grid.Row="2" ItemsSource="{Binding Days}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<UniformGrid Columns="7" Rows="6"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate x:DataType="vm:YearDayItem">
											<Button Margin="1" Padding="0" Background="Transparent" BorderThickness="0"
                                                    Height="30" CornerRadius="4"
                                                    Command="{Binding DataContext.SelectDayCommand, ElementName=Root}"
                                                    CommandParameter="{Binding}">
												<Grid RowDefinitions="*, Auto" Margin="0,2">
													<TextBlock Text="{Binding DayNumber}"
                                                               FontSize="11"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
													<Ellipse Grid.Row="1" Width="4" Height="4" Fill="#3B82F6"
                                                             IsVisible="{Binding HasTasks}"
                                                             HorizontalAlignment="Center" Margin="0,1,0,0"/>
												</Grid>
											</Button>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>