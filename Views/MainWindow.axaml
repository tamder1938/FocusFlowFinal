<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FocusFlowFinal.ViewModels"
        xmlns:views="using:FocusFlowFinal.Views"
        xmlns:controls="using:FocusFlowFinal.Views.Controls"
        x:Class="FocusFlowFinal.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="FocusFlow"
        Width="1280" Height="820"
        MinWidth="1000" MinHeight="600"
        Background="{DynamicResource WindowBackgroundBrush}">

<Window.DataTemplates>
		<DataTemplate DataType="vm:DayViewModel">   <views:DayView/></DataTemplate>
		<DataTemplate DataType="vm:WeekViewModel">  <views:WeekView/></DataTemplate>
		<DataTemplate DataType="vm:MonthViewModel"> <views:MonthView/></DataTemplate>
		<DataTemplate DataType="vm:YearViewModel">  <views:YearView/></DataTemplate>
		<DataTemplate DataType="vm:TaskListViewModel"><views:TaskListView/></DataTemplate>
		<DataTemplate DataType="vm:TimerViewModel"> <views:TimerView/></DataTemplate>
	</Window.DataTemplates>

	<Window.Styles>
		<!-- ── Навигационная пилюля (активная) ─────────────────────── -->
		<Style Selector="Button.nav-pill">
			<Setter Property="Background"      Value="{DynamicResource NavInactiveBg}"/>
			<Setter Property="Foreground"      Value="{DynamicResource NavInactiveFg}"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="14,6"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="Medium"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.nav-pill:pointerover">
			<Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
			<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
		</Style>
		<Style Selector="Button.nav-pill.active">
			<Setter Property="Background" Value="{DynamicResource NavActiveBg}"/>
			<Setter Property="Foreground" Value="{DynamicResource NavActiveFg}"/>
		</Style>
		<Style Selector="Button.nav-pill.active:pointerover">
			<Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<!-- ── Кнопка «Сегодня» ──────────────────────────────────────── -->
		<Style Selector="Button.today-btn">
			<Setter Property="Background"      Value="{DynamicResource ButtonBackgroundBrush}"/>
			<Setter Property="Foreground"      Value="{DynamicResource PrimaryTextBrush}"/>
			<Setter Property="BorderBrush"     Value="{DynamicResource ButtonBorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="12,5"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>

		<!-- ── Кнопка «+ Задача» ─────────────────────────────────────── -->
		<Style Selector="Button.add-task-btn">
			<Setter Property="Background"      Value="{DynamicResource AccentBackground}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="14,6"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.add-task-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
		</Style>

		<!-- ── Иконка-кнопка (луна, шестерёнка) ─────────────────────── -->
		<Style Selector="Button.icon-btn">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Width"           Value="32"/>
			<Setter Property="Height"          Value="32"/>
			<Setter Property="CornerRadius"    Value="6"/>
			<Setter Property="Padding"         Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment"   Value="Center"/>
			<Setter Property="Cursor"          Value="Hand"/>
		</Style>
		<Style Selector="Button.icon-btn:pointerover">
			<Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="52, *">

		<!-- ═══════════════════════════════════════════════════════════
		     ШАПКА: Logo | Nav | Date + Сегодня + Задача | Moon | Gear
		     ═══════════════════════════════════════════════════════════ -->
		<Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto, Auto" Margin="16,0">

				<!-- Логотип -->
				<StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="8" VerticalAlignment="Center" Margin="0,0,20,0">
					<Border Width="28" Height="28" CornerRadius="6"
                            Background="{DynamicResource AccentBackground}">
						<TextBlock Text="F" Foreground="White" FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<TextBlock Text="FocusFlow" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
				</StackPanel>

				<!-- Навигационные пилюли -->
				<Border Grid.Column="1"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        CornerRadius="8" Padding="4,3">
					<StackPanel Orientation="Horizontal" Spacing="2">
						<Button Classes="nav-pill"
                                Classes.active="{Binding IsDayView}"
                                Content="{Binding Loc[TitleDay]}"
                                Command="{Binding SwitchToDayCommand}"
                                ToolTip.Tip="{Binding HotkeyDayLabel}"/>
						<Button Classes="nav-pill"
                                Classes.active="{Binding IsWeekView}"
                                Content="{Binding Loc[TitleWeek]}"
                                Command="{Binding SwitchToWeekCommand}"
                                ToolTip.Tip="{Binding HotkeyWeekLabel}"/>
						<Button Classes="nav-pill"
                                Classes.active="{Binding IsMonthView}"
                                Content="{Binding Loc[TitleMonth]}"
                                Command="{Binding SwitchToMonthCommand}"
                                ToolTip.Tip="{Binding HotkeyMonthLabel}"/>
						<Button Classes="nav-pill"
                                Classes.active="{Binding IsYearView}"
                                Content="{Binding Loc[TitleYear]}"
                                Command="{Binding SwitchToYearCommand}"
                                ToolTip.Tip="{Binding HotkeyYearLabel}"/>
					</StackPanel>
				</Border>

				<!-- Дата + Сегодня + Задача -->
				<StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="8">
					<TextBlock Text="{Binding SelectedDateFormatted}"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
					<Button Classes="today-btn"
                            Content="{Binding Loc[TodayBtn]}"
                            Command="{Binding GoToTodayCommand}"
                            ToolTip.Tip="{Binding HotkeyTodayLabel}"/>
					<Button Classes="add-task-btn"
                            Command="{Binding CurrentTaskListViewModel.AddTaskCommand}"
                            ToolTip.Tip="{Binding HotkeyNewTaskLabel}">
						<StackPanel Orientation="Horizontal" Spacing="6">
							<TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
							<TextBlock Text="{Binding Loc[Tasks]}" VerticalAlignment="Center"/>
						</StackPanel>
					</Button>
				</StackPanel>

				<!-- Привычки + Финансы (всегда видны) + ⋯ Ещё (остальные модули) -->
				<StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="2" Margin="8,0,4,0">
					<Button IsEnabled="{Binding IsHabitTrackerEnabled}"
                            Command="{Binding OpenHabitsCommand}"
                            Content="{Binding Loc[Habits]}"
                            Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6" Padding="12,5" FontSize="13"
                            FontWeight="Medium" Cursor="Hand"
                            ToolTip.Tip="{Binding Loc[Finance_EnabledInSettings]}"/>
					<Button IsEnabled="{Binding IsFinanceModuleEnabled}"
                            Command="{Binding OpenFinanceCommand}"
                            Content="{Binding Loc[Finance]}"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource OnAccentBrush}"
                            BorderThickness="0"
                            CornerRadius="6" Padding="12,5" FontSize="13"
                            FontWeight="SemiBold" Cursor="Hand" Margin="2,0,0,0"
                            ToolTip.Tip="{Binding Loc[Finance_EnabledInSettings]}"/>
					<!-- ⋯ Ещё: flyout со всеми остальными модулями -->
					<Button Background="{DynamicResource ButtonBackgroundBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6" Padding="12,5" FontSize="13"
                            FontWeight="Medium" Cursor="Hand" Margin="2,0,0,0"
                            ToolTip.Tip="Ещё модули">
						<Button.Flyout>
							<Flyout Placement="BottomEdgeAlignedRight">
								<StackPanel Spacing="1" Margin="4" Width="240">
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenMoodCommand}"
                                            IsVisible="{Binding IsMoodTrackerEnabled}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="😊" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Feat_MoodTrackerLbl]}" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenNotesCommand}"
                                            IsVisible="{Binding IsNotesAndDiaryEnabled}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="📝" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Feat_NotesAndDiaryLbl]}" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenWorkoutCommand}"
                                            IsVisible="{Binding IsWorkoutTrackerEnabled}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="🏋️" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Feat_WorkoutTrackerLbl]}" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenMediaCommand}"
                                            IsVisible="{Binding IsMediaTrackerEnabled}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="🎬" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Feat_MediaTrackerLbl]}" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenPlacesCommand}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="📍" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="Места" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenWishlistCommand}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="🛍️" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Wishlists]}" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenFriendsCommand}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="👥" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="Друзья" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenCalendarShareCommand}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="📅" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="Общий доступ к календарю" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
									<Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="10,7" CornerRadius="6" Cursor="Hand"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding OpenTemplatesCommand}">
										<StackPanel Orientation="Horizontal" Spacing="10">
											<TextBlock Text="📋" FontSize="14" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Loc[Templates]}" FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
										</StackPanel>
									</Button>
								</StackPanel>
							</Flyout>
						</Button.Flyout>
						<TextBlock Text="⋯ Ещё" FontSize="13" VerticalAlignment="Center"/>
					</Button>
				</StackPanel>

				<!-- Иконка настроек — всегда закреплена справа -->
				<Button Grid.Column="5" Classes="icon-btn"
                        Command="{Binding OpenSettingsCommand}"
                        VerticalAlignment="Center" Margin="4,0,0,0"
                        ToolTip.Tip="{Binding Loc[Settings]}">
					<PathIcon Width="16" Height="16"
                              Foreground="{DynamicResource SecondaryTextBrush}"
                              Data="M19.14 12.94c.04-.3.06-.61.06-.94s-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
				</Button>

			</Grid>
		</Border>

		<!-- ═══════════════════════════════════════════════════════════
		     КОНТЕНТ: Календарь | Задачи | Таймер+Аналитика
		     ═══════════════════════════════════════════════════════════ -->
		<Grid Grid.Row="1" ColumnDefinitions="2.2*, 1.2*, 1*" Margin="12,12,12,12">

			<!-- Календарь -->
			<Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,6,0"
                    ClipToBounds="True"
                    BoxShadow="0 2 8 0 #08000000">
				<ContentControl Content="{Binding CurrentCalendarView}"/>
			</Border>

			<!-- Задачи -->
			<Border Grid.Column="1"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,6,0"
                    ClipToBounds="True"
                    BoxShadow="0 2 8 0 #08000000">
				<ContentControl Content="{Binding CurrentTaskListViewModel}"/>
			</Border>

			<!-- Таймер + Аналитика -->
			<ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
				<StackPanel Spacing="10">

					<!-- Таймер -->
					<Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            ClipToBounds="True"
                            BoxShadow="0 2 8 0 #08000000">
						<ContentControl Content="{Binding CurrentTimerViewModel}"/>
					</Border>

					<!-- Фоновые звуки -->
					<Panel IsVisible="{Binding IsBackgroundSoundsEnabled}">
						<controls:SoundPlayerWidget DataContext="{Binding SoundViewModel}"/>
					</Panel>

					<!-- Аналитика -->
					<Border Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="16"
                            BoxShadow="0 2 8 0 #08000000">
						<StackPanel Spacing="8">

							<TextBlock Text="{Binding Loc[AnalyticsTitle]}"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
							<TextBlock Text="{Binding Loc[PlanVsFactToday]}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,4"/>

							<!-- Plan -->
							<Grid ColumnDefinitions="*, Auto">
								<TextBlock Grid.Column="0" Text="{Binding Loc[Plan]}"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
								<TextBlock Grid.Column="1" Text="{Binding TodayPlanTimeStr}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
							</Grid>
							<ProgressBar Value="100" Height="4" Minimum="0" Maximum="100"
                                         Background="{DynamicResource ProgressBackgroundBrush}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         CornerRadius="2" Margin="0,0,0,4"/>

							<!-- Fact -->
							<Grid ColumnDefinitions="*, Auto">
								<TextBlock Grid.Column="0" Text="{Binding Loc[Fact]}"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
								<TextBlock Grid.Column="1" Text="{Binding TodayFactTimeStr}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
							</Grid>
							<ProgressBar Value="{Binding TodayFactProgress}"
                                         Height="4" Minimum="0" Maximum="100"
                                         Background="{DynamicResource ProgressBackgroundBrush}"
                                         Foreground="#10B981"
                                         CornerRadius="2" Margin="0,0,0,6"/>

							<!-- Отклонение + Подробнее -->
							<Grid ColumnDefinitions="*, Auto">
								<StackPanel Grid.Column="0" Orientation="Horizontal"
                                            Spacing="4" VerticalAlignment="Center">
									<TextBlock Text="{Binding Loc[Deviation]}:"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
									<TextBlock Text="{Binding TodayDeviationStr}"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{Binding TodayDeviationColor}"/>
								</StackPanel>
								<Button Grid.Column="1"
                                        Content="{Binding Loc[MoreBtn]}"
                                        Command="{Binding OpenAnalyticsCommand}"
                                        FontSize="11" Padding="10,5"
                                        Background="Transparent"
                                        Foreground="{DynamicResource AccentBackground}"
                                        BorderBrush="{DynamicResource AccentBackground}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"/>
							</Grid>
						</StackPanel>
					</Border>

				</StackPanel>
			</ScrollViewer>

		</Grid>
	</Grid>
</Window>
